# Copie para .env na raiz do repositorio, em BACKEND/ ou em BACKEND/pipeline/
# (loadEnv carrega nessa ordem; raiz pode sobrescrever).
#
# --- Dados (uma das opcoes) ---
# PostgreSQL: DATABASE_URL ou PGHOST + PGDATABASE + PGUSER + PGPASSWORD
#
# CSV direto (Node le dados/ e agrega; sem replica SQLite):
# DATA_SOURCE=csv
# CSV_DATOS_DIR=dados
#
# DuckDB local (query engine sobre CSV em dados/):
# DATA_SOURCE=duckdb
# CSV_DATOS_DIR=dados
# DUCKDB_PATH=db local/hospital_bi.duckdb
# (use DUCKDB_PATH=:memory: para banco temporario em memoria)
#
# SQLite replica (omissao se existir db local/db_testes_replica.sqlite3):
# SQLITE_PATH=db local/db_testes_replica.sqlite3
#
# Porta da API (nao usar PORT da raiz se for de outra app)
# HOSPITAL_BI_API_PORT=3020
#
# --- Redis / cache stale (opcional; ver docker-compose.yml) ---
# REDIS_URL=redis://127.0.0.1:6379
# REDIS_OFFLINE_USE_MEMORY=1
# CACHE_FORCE_MEMORY=0
# DB_FALLBACK_READ_STALE=1
# DB_FALLBACK_WRITE_STALE=1
# DB_FALLBACK_STALE_TTL_SEC=86400
# BIND_HOST=127.0.0.1
#
# --- Gerencia / CSV (opcional) ---
# Leituras CSV em paralelo por lote (1 = sequencial; omissao 3)
# GERENCIA_CSV_PARALLEL_FETCHES=3
# Cache em memoria do dataset por periodo (ms; min 5 s, max 10 min; omissao 120000)
# GERENCIA_DATASET_TTL_MS=120000
#
# --- Gerencia / cache quente progressivo (DuckDB/CSV) ---
# Janela quente em memoria/Redis (ms; omissao 6h)
# GERENCIA_HOT_WINDOW_TTL_MS=21600000
# Segunda onda (30 -> 60 dias) apos X ms; omissao 600000 (10 min)
# GERENCIA_WARM_SECOND_WAVE_DELAY_MS=600000
