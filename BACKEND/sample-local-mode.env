# Copie para .env na raiz do repositório, em BACKEND/ ou em BACKEND/pipeline/ (loadEnv carrega nessa ordem).
#
# --- Dados (uma das opções) ---
# PostgreSQL: DATABASE_URL ou PGHOST + PGDATABASE + PGUSER + PGPASSWORD
#
# CSV direto (Node lê dados/ e agrega; sem réplica SQLite):
# DATA_SOURCE=csv
# CSV_DATOS_DIR=dados
#
# SQLite réplica (omissão se existir db local/db_testes_replica.sqlite3):
# SQLITE_PATH=db local/db_testes_replica.sqlite3
#
# Porta da API (não usar PORT da raiz se for de outra app)
# HOSPITAL_BI_API_PORT=3020
#
# --- Redis / cache stale (opcional; ver docker-compose.yml) ---
# REDIS_URL=redis://127.0.0.1:6379
# REDIS_OFFLINE_USE_MEMORY=1
# CACHE_FORCE_MEMORY=0
# DB_FALLBACK_READ_STALE=1
# DB_FALLBACK_WRITE_STALE=1
# DB_FALLBACK_STALE_TTL_SEC=86400
# BIND_HOST=127.0.0.1
