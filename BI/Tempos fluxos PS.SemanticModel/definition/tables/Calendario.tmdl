	column 'Semana (rótulo)' = ```
			
			    FORMAT('Calendario'[Semana Início], "dd/MM") 
			    & " a " 
			    & FORMAT('Calendario'[Semana Fim], "dd/MM")
			```
		lineageTag: 84b9fd43-13b9-44de-a109-e77fc66bffe9
