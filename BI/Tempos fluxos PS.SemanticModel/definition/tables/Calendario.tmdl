	column EhMesFechado = ```
			
			VAR PrimeiroDiaMesAtual =
			    DATE ( YEAR ( TODAY() ), MONTH ( TODAY() ), 1 )
			RETURN
			    IF (
			        'Calendario'[Data] < PrimeiroDiaMesAtual,
			        "Sim",    // Se a data for anterior ao primeiro dia do mês atual
			        "Não"     // Caso contrário
			    )
			
			
			```
		lineageTag: 04c3c62a-6042-4580-82b2-239295fc060c
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Semana Início' = 'Calendario'[Data] - WEEKDAY('Calendario'[Data], 1) + 1
