	column AnoSemana =
			
			VAR Inicio = 'Calendario'[Semana Início]
			RETURN
			    YEAR(Inicio) * 100 + WEEKNUM(Inicio, 1)   -- 1 = semana começa no domingo
		lineageTag: c08cc3a5-2c31-4f72-9e19-16075269c513
		summarizeBy: sum

		changedProperty = SortByColumn

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Semana do Ano' =
			
			WEEKNUM ( 'Calendario'[Semana Início], 1 )   -- 1 = semana começa no domingo
		formatString: 0
