	column InicioMes = DATE(YEAR('Calendario'[Data]), MONTH('Calendario'[Data]), 1)
		formatString: General Date
		lineageTag: bedb1b58-c18d-4e96-888c-c35bd312aec5
		summarizeBy: none

		variation Variation
			isDefault
			relationship: 3f809bab-1298-4ed1-b6b5-a8474190ecaa
			defaultHierarchy: LocalDateTable_093e9804-aa0a-4554-922b-d50c98cb7434.'Hierarquia de datas'

		annotation SummarizationSetBy = Automatic

	partition Calendario = m
		mode: import
		source = ```
				let
				    // Datas de início e fim
				    DataInicio = #date(2025, 1, 1),
				    DataFim = #date(Date.Year(DateTime.LocalNow()), 12, 31),
				 
				    // Lista de datas
				    ListaDatas = List.Dates(DataInicio, Duration.Days(Duration.From(DataFim - DataInicio)) + 1, #duration(1, 0, 0, 0)),
				    TabelaDatas = Table.FromList(ListaDatas, Splitter.SplitByNothing(), {"Data"}),
				 
				    // Adiciona colunas úteis
				    DatasComAno = Table.AddColumn(TabelaDatas, "Ano", each Date.Year([Data]), Int64.Type),
				    DatasComMes = Table.AddColumn(DatasComAno, "Mês", each Date.Month([Data]), Int64.Type),
				    DatasComNomeMes = Table.AddColumn(DatasComMes, "Nome Mês", each Date.ToText([Data], "MMMM"), type text),
				    DatasComTrimestre = Table.AddColumn(DatasComNomeMes, "Trimestre", each "T" & Number.ToText(Date.QuarterOfYear([Data])), type text),
				    DatasComSemestre = Table.AddColumn(DatasComTrimestre, "Semestre", each "S" & Number.ToText(Number.RoundUp(Date.QuarterOfYear([Data]) / 2)), type text),
				    DatasComDiaSemana = Table.AddColumn(DatasComSemestre, "Dia da Semana", each Date.DayOfWeek([Data]) + 1, Int64.Type),
				    DatasComNomeDiaSemana = Table.AddColumn(DatasComDiaSemana, "Nome Dia Semana", each Text.Proper(Date.ToText([Data], "dddd")), type text),
				    DatasComFinalSemana = Table.AddColumn(DatasComNomeDiaSemana, "É Final de Semana?", each if List.Contains({0, 6}, Date.DayOfWeek([Data])) then "Sim" else "Não", type text),
				    DatasComDia = Table.AddColumn(DatasComFinalSemana, "Dia", each Date.Day([Data]), Int64.Type),
				    DatasComMesAno = Table.AddColumn(DatasComDia, "Mes e Ano", each Text.Combine({Text.Start(Text.Proper([Nome Mês]), 3), " ", Text.From([Ano], "pt-BR")}), type text),
				    DatasComAnoMesNum = Table.AddColumn(DatasComMesAno, "Ano Mes Num", each Text.Combine({Text.From([Ano], "pt-BR"), Text.PadStart(Text.From([Mês], "pt-BR"), 2, "0")}), type text),
				    DatasComAnoMesNumTipo = Table.TransformColumnTypes(DatasComAnoMesNum,{{"Ano Mes Num", Int64.Type}}),
				 
				    // Geração automática dos feriados fixos
				    Anos = {2025..Date.Year(DateTime.LocalNow())},
				    FeriadosFixos = Table.Combine(
				        List.Transform(Anos, each
				            let
				                ano = _,
				                feriados = {
				                    {#date(ano, 1, 1), "Confraternização Universal"},
				                    {#date(ano, 4, 21), "Tiradentes"},
				                    {#date(ano, 5, 1), "Dia do Trabalho"},
				                    {#date(ano, 9, 7), "Independência do Brasil"},
				                    {#date(ano, 10, 12), "Nossa Senhora Aparecida"},
				                    {#date(ano, 11, 2), "Finados"},
				                    {#date(ano, 11, 15), "Proclamação da República"},
				                    {#date(ano, 11, 20), "Dia da Consciência Negra"},
				                    {#date(ano, 12, 25), "Natal"}
				                }
				            in
				                Table.FromRows(feriados, {"Data", "Nome Feriado"})
				        )
				    ),
				 
				    // Feriados móveis
				    CalcularFeriadosMoveis = (ano as number) as table =>
				        let
				            a = Number.Mod(ano, 19),
				            b = Number.IntegerDivide(ano, 100),
				            c = Number.Mod(ano, 100),
				            d = Number.IntegerDivide(b, 4),
				            e = Number.Mod(b, 4),
				            f = Number.IntegerDivide(b + 8, 25),
				            g = Number.IntegerDivide(b - f + 1, 3),
				            h = Number.Mod(19 * a + b - d - g + 15, 30),
				            i = Number.IntegerDivide(c, 4),
				            k = Number.Mod(c, 4),
				            l = Number.Mod(32 + 2 * e + 2 * i - h - k, 7),
				            m = Number.IntegerDivide(a + 11 * h + 22 * l, 451),
				            mesPascoa = Number.IntegerDivide(h + l - 7 * m + 114, 31),
				            diaPascoa = Number.Mod(h + l - 7 * m + 114, 31) + 1,
				            dataPascoa = #date(ano, mesPascoa, diaPascoa),
				            feriadosMoveis = {
				                {Date.AddDays(dataPascoa, -47), "Carnaval"},
				                {Date.AddDays(dataPascoa, -2), "Sexta-feira Santa"},
				                {dataPascoa, "Páscoa"},
				                {Date.AddDays(dataPascoa, 60), "Corpus Christi"}
				            }
				        in
				            Table.FromRows(feriadosMoveis, {"Data", "Nome Feriado"}),
				 
				    FeriadosMoveis = Table.Combine(List.Transform(Anos, each CalcularFeriadosMoveis(_))),
				    TodosFeriados = Table.Combine({FeriadosFixos, FeriadosMoveis}),
				
				    // 1 linha por Data (evita duplicar o calendário)
				    TodosFeriadosAgrupado =
				        Table.Group(
				            TodosFeriados,
				            {"Data"},
				            {{"Nome Feriado", each Text.Combine(List.Distinct([Nome Feriado]), " / "), type text}}
				        ),
				
				    // Join com calendário
				    D_CalendarioFinal = Table.NestedJoin(DatasComAnoMesNumTipo, "Data", TodosFeriadosAgrupado, "Data", "Feriado", JoinKind.LeftOuter),
				    ExpandirFeriados = Table.ExpandTableColumn(D_CalendarioFinal, "Feriado", {"Nome Feriado"}, {"Nome Feriado"}),
				    D_CalendarioCompleta = Table.AddColumn(ExpandirFeriados, "É Feriado?", each if [Nome Feriado] <> null then "Sim" else "Não", type text),
				    #"Tipo Alterado" = Table.TransformColumnTypes(D_CalendarioCompleta, {{"Data", type date}})
				in
				    #"Tipo Alterado"
				```

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navegação

