	measure 'Medida Dinâmica' = ```
			
			VAR SelecaoParametro = SELECTEDVALUE('Tabela_Parametro_Medidas'[Parametro])
			
			RETURN
			    SWITCH(
			        SelecaoParametro,
			
			        // --- CONSULTAS >1:30H usa Fluxo[HR_CONSULTA] ---
			        "CONSULTAS >1:30H",
			            CALCULATE(
			                [Qtd Consulta >1:30h],
			                USERELATIONSHIP(Fluxo[HR_CONSULTA], HORAS[HORAS]),
			                TREATAS(VALUES(HORAS[HORAS]), Fluxo[HR_CONSULTA])
			            ),
			
			        // --- TRIAGEM >12MIN usa Fluxo[HR_ENTRADA] ---
			        "TRIAGEM >12MIN",
			            CALCULATE(
			                [Qtd Triagem >12min],
			                USERELATIONSHIP(Fluxo[HR_ENTRADA], HORAS[HORAS]),
			                TREATAS(VALUES(HORAS[HORAS]), Fluxo[HR_ENTRADA])
			            ),
			
			        // --- MEDICAÇÕES >30MIN usa medicacao[HR_MEDICACAO] ---
			        "MEDICAÇÕES >30MIN",
			            CALCULATE(
			                [Qtd Medicações >30min],
			                USERELATIONSHIP(medicacao[HR_MEDICACAO], HORAS[HORAS]),
			                TREATAS(VALUES(HORAS[HORAS]), medicacao[HR_MEDICACAO])
			            ),
			
			        // --- RX E ECG >45MIN usa 'RX e ECG'[HR_RX_ECG] ---
			        "RX E ECG >45MIN",
			            CALCULATE(
			                [Qtd RX_ECG >45min],
			                USERELATIONSHIP('RX e ECG'[HR_RX_ECG], HORAS[HORAS]),
			                TREATAS(VALUES(HORAS[HORAS]), 'RX e ECG'[HR_RX_ECG])
			            ),
			
			        // --- TC e US >2H usa 'TC e US'[HR_TC_US] ---
			        "TC e US >2H",
			            CALCULATE(
			                [Qtd TC_US >2H],
			                USERELATIONSHIP('TC e US'[HR_TC_US], HORAS[HORAS]),
			                TREATAS(VALUES(HORAS[HORAS]), 'TC e US'[HR_TC_US])
			            ),
			
			        // --- REAVALIAÇÕES >45MIN usa reavaliacao[HR_REAVALIACAO] ---
			        "REAVALIAÇÕES >45MIN",
			            CALCULATE(
			                [Qtd Reavaliações >45min],
			                USERELATIONSHIP(reavaliacao[HR_REAVALIACAO], HORAS[HORAS]),
			                TREATAS(VALUES(HORAS[HORAS]), reavaliacao[HR_REAVALIACAO])
			            ),
			
			        // --- PERMANÊNCIA >3H usa Fluxo[HR_ALTA] ---
			        "PERMANÊNCIA >3H",
			            CALCULATE(
			                [Qtd Alta > 3h],
			                USERELATIONSHIP(Fluxo[HR_ALTA], HORAS[HORAS]),
			                TREATAS(VALUES(HORAS[HORAS]), Fluxo[HR_ALTA])
			            ),
			
			        // --- ATENDIMENTOS usa Fluxo[HR_ENTRADA] ---
			        "ATENDIMENTOS",
			            CALCULATE(
			                [Qtd Atend],
			                USERELATIONSHIP(Fluxo[HR_ENTRADA], HORAS[HORAS]),
			                TREATAS(VALUES(HORAS[HORAS]), Fluxo[HR_ENTRADA])
			            ),
			
			        // --- Fallback caso nada esteja selecionado ---
			        BLANK()
			    )
			
			```
		formatString: 0
		displayFolder: OUTROS
		lineageTag: 9ae348a0-fcef-448d-a69f-05f23bd7aa39

