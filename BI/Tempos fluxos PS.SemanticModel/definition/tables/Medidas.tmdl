	measure '% Atend > Tempo procedimento' =
			
			VAR LimiteMinutos = Meta_procedimento[Valor Meta_procedimento]
			VAR AtendAcima =
			    CALCULATE (
			        COUNT ( procedimento[NR_ATENDIMENTO]),
			        FILTER (
			            procedimento,
			            procedimento[MINUTOS] > LimiteMinutos
			        )
			    )
			VAR TotalAtend =
			    CALCULATE ( COUNT ( procedimento[NR_ATENDIMENTO] ) )
			RETURN
			DIVIDE ( AtendAcima, TotalAtend, 0 )
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: PROCEDIMENTO
		lineageTag: eaa04a57-0842-498c-9753-1eac6f1033ff

