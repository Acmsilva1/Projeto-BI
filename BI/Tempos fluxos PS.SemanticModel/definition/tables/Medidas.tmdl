	measure '_Ind Vol - YTD diff pp (só última coluna)' =
			
			VAR _Ind = SELECTEDVALUE ( 'Dim Indicadores Volume'[Indicador] )
			VAR _IsWeek = ISINSCOPE ( 'Calendario'[Semana (rótulo)] )
			VAR _EhColunaTotal =
			    NOT ISINSCOPE ( 'Calendario'[Mes e Ano] )
			        && NOT ISINSCOPE ( 'Calendario'[Semana (rótulo)] )
			VAR _MostrarYtd = _EhColunaTotal
			VAR _Ano = YEAR ( MAX ( 'Calendario'[Data] ) )
			VAR _CalVis =
			    SUMMARIZE (
			        ALLSELECTED ( 'Calendario' ),
			        'Calendario'[Ano Mes Num],
			        'Calendario'[AnoSemana],
			        'Calendario'[Semana Início],
			        'Calendario'[Data]
			    )
			VAR _MaxMes =
			    MAXX (
			        FILTER ( _CalVis, INT ( 'Calendario'[Ano Mes Num] / 100 ) = _Ano ),
			        'Calendario'[Ano Mes Num]
			    )
			VAR _MaxSem =
			    MAXX (
			        FILTER ( _CalVis, YEAR ( 'Calendario'[Semana Início] ) = _Ano ),
			        'Calendario'[AnoSemana]
			    )
			VAR _CurrMes = MAX ( 'Calendario'[Ano Mes Num] )
			VAR _CurrSem = MAX ( 'Calendario'[AnoSemana] )
			VAR _IsLastCol =
			    IF ( _IsWeek, _CurrSem = _MaxSem, _CurrMes = _MaxMes )
			VAR _MinMes =
			    MINX (
			        FILTER ( _CalVis, INT ( 'Calendario'[Ano Mes Num] / 100 ) = _Ano ),
			        'Calendario'[Ano Mes Num]
			    )
			VAR _MinSem =
			    MINX (
			        FILTER ( _CalVis, YEAR ( 'Calendario'[Semana Início] ) = _Ano ),
			        'Calendario'[AnoSemana]
			    )
			VAR _NumSemanasNoRecorte =
			    COUNTROWS (
			        SUMMARIZE (
			            FILTER ( _CalVis, YEAR ( 'Calendario'[Semana Início] ) = _Ano ),
			            'Calendario'[AnoSemana]
			        )
			    )
			VAR _UmMesSo = _MinMes = _MaxMes
			VAR _VBruto = [Valor Indicador Volume]
			VAR _V =
			    IF (
			        _MostrarYtd && _UmMesSo && _NumSemanasNoRecorte > 1,
			        CALCULATE (
			            [Valor Indicador Volume],
			            'Calendario'[Ano Mes Num] = _MaxMes,
			            REMOVEFILTERS ( 'Calendario'[Semana (rótulo)] )
			        ),
			        _VBruto
			    )
			VAR _IniPrimeiraSem =
			    MINX (
			        FILTER ( _CalVis, 'Calendario'[AnoSemana] = _MinSem ),
			        'Calendario'[Semana Início]
			    )
			VAR _VIniSem =
			    CALCULATE (
			        [Valor Indicador Volume],
			        TREATAS ( { _IniPrimeiraSem }, 'Calendario'[Semana Início] ),
			        REMOVEFILTERS (
			            'Calendario'[Semana (rótulo)],
			            'Calendario'[Mes e Ano],
			            'Calendario'[Ano Mes Num]
			        )
			    )
			VAR _MesJaneiroAno = _Ano * 100 + 1
			VAR _VIniMes =
			    CALCULATE (
			        [Valor Indicador Volume],
			        TREATAS ( { _MesJaneiroAno }, 'Calendario'[Ano Mes Num] ),
			        REMOVEFILTERS (
			            'Calendario'[Semana (rótulo)],
			            'Calendario'[Mes e Ano],
			            'Calendario'[Data]
			        )
			    )
			VAR _VIni = _VIniMes
			RETURN
			    IF (
			        NOT _MostrarYtd
			            || ISBLANK ( _Ind )
			            || NOT _IsLastCol
			            || ISBLANK ( _V )
			            || ISBLANK ( _VIni ),
			        BLANK (),
			        _V - _VIni
			    )
		lineageTag: fa8a9f95-e53c-4516-a765-1a15849fa116

