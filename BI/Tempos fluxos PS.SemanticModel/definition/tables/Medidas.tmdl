	measure 'Qtd Atend > Tempo procedimento' =
			
			VAR LimiteMinutos = Meta_procedimento[Valor Meta_procedimento]        -- medida do parâmetro
			RETURN
			CALCULATE (
			    COUNT ( procedimento[NR_ATENDIMENTO] ),
			    FILTER (
			        procedimento,
			        procedimento[MINUTOS] > LimiteMinutos
			    )
			) + 0
