	measure '% Atend > Tempo reavaliacao (0)' = ```
			
			VAR LimiteMinutos =
			    COALESCE ( [Valor Meta_reavaliacao], 0 )
			VAR AtendAcima =
			    CALCULATE (
			        COUNT ( reavaliacao[NR_ATENDIMENTO] ),
			        FILTER (
			            reavaliacao,
			            VAR DtIni = reavaliacao[DT_SOLIC_REAVALIACAO]
			            VAR DtEvo = reavaliacao[DT_EVO_PRESC]
			            VAR DtFim = reavaliacao[DT_FIM_REAVALIACAO]
			            VAR DtRef =
			                SWITCH (
			                    TRUE (),
			                    ISBLANK ( DtEvo ) && ISBLANK ( DtFim ), BLANK (),
			                    ISBLANK ( DtEvo ), DtFim,
			                    ISBLANK ( DtFim ), DtEvo,
			                    DtEvo <= DtFim, DtEvo,
			                    DtFim
			                )
			            VAR Minutos = DATEDIFF ( DtIni, DtRef, MINUTE )
			            RETURN
			                NOT ISBLANK ( DtIni )
			                    && NOT ISBLANK ( DtRef )
			                    && Minutos > LimiteMinutos
			        )
			    )
			VAR TotalAtend =
			    CALCULATE (
			        COUNT ( reavaliacao[NR_ATENDIMENTO] ),
			        FILTER (
			            reavaliacao,
			            NOT ISBLANK ( reavaliacao[DT_SOLIC_REAVALIACAO] )
			                && (
			                    NOT ISBLANK ( reavaliacao[DT_EVO_PRESC] )
			                        || NOT ISBLANK ( reavaliacao[DT_FIM_REAVALIACAO] )
			                )
			        )
			    )
			RETURN
			    IF (
			        TotalAtend = 0 || ISBLANK ( TotalAtend ),
			        BLANK (),
			        DIVIDE ( AtendAcima, TotalAtend, 0 ) + 0
			    )
			
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: REAVALIACAO
		lineageTag: 53bd84f5-3141-4fe7-8928-6019f650b98c

