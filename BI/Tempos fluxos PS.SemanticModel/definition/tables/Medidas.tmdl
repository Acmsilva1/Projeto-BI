	measure 'Eh_SuperUsuario (pac)' = ```
			
			VAR DataRef    = MAXX(ALL(fluxo), fluxo[DATA]) - 1
			VAR Dias       = SELECTEDVALUE(Qtde_dias[Qtde_dias], 30)
			VAR DataInicio = DataRef - Dias
			VAR Limite     = SELECTEDVALUE(Qtde_atd[Qtde_atd], BLANK())
			VAR Paciente   = SELECTEDVALUE(fluxo[CD_PESSOA_FISICA])
			VAR T =
			    SUMMARIZECOLUMNS(
			        fluxo[CD_PESSOA_FISICA],
			        FILTER(
			            ALL(fluxo),
			            fluxo[DATA] >= DataInicio && fluxo[DATA] <= DataRef
			        ),
			        "Qtd", COUNTROWS(fluxo)
			    )
			VAR QtdPaciente =
			    MAXX(
			        FILTER(T, fluxo[CD_PESSOA_FISICA] = Paciente),
			        [Qtd]
			    )
			RETURN
			IF(
			    ISBLANK(Limite),
			    "Normal",
			    IF(QtdPaciente >= Limite, "Superusuário", "Normal")
			)
			
			
			```
		displayFolder: SUPER USUARIOS
		lineageTag: 0fbbaa1f-0292-4f1a-9442-d5d3cd62d9c9

	measure 'Entre datas SU' =
			
			VAR DataRef  = MAXX(ALL(fluxo), fluxo[DATA]) - 1
			VAR Dias     = SELECTEDVALUE(Qtde_dias[Qtde_dias], 30)
			VAR DataIni  = DataRef - Dias
			VAR TotalSemFiltro = CALCULATE( COUNTROWS( calendario ), ALL( calendario ) )
			
			VAR ParamMax =
			    IF(
			        COUNTROWS( VALUES( calendario[data] ) ) = TotalSemFiltro,
			        CALCULATE( MAX( calendario[data] ), ALL( calendario ) ),  -- Todos
			        CALCULATE( MAX( calendario[data] ) )                       -- Filtrado
			    )
			
			RETURN
			"de " & FORMAT(DataIni, "dd/MM/yyyy") &  " a " & FORMAT(DataRef, "dd/MM/yyyy") & " (últimos " & Dias & " dias" & ")"
		displayFolder: SUPER USUARIOS
