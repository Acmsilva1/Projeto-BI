	measure 'Qtd Atend > Tempo reavaliacao' =
			
			VAR LimiteMinutos = [Valor Meta_reavaliacao]
			RETURN
			CALCULATE (
			    COUNT ( reavaliacao[NR_ATENDIMENTO] ),
			    FILTER (
			        reavaliacao,
			        VAR DtIni = reavaliacao[DT_SOLIC_REAVALIACAO]
			        VAR DtEvo = reavaliacao[DT_EVO_PRESC]
			        VAR DtFim = reavaliacao[DT_FIM_REAVALIACAO]
			        VAR DtRef =
			            SWITCH (
			                TRUE (),
			                ISBLANK ( DtEvo ) && ISBLANK ( DtFim ), BLANK (),
			                ISBLANK ( DtEvo ), DtFim,
			                ISBLANK ( DtFim ), DtEvo,
			                DtEvo <= DtFim, DtEvo,
			                DtFim
			            )
			        VAR Minutos = DATEDIFF ( DtIni, DtRef, MINUTE )
			        RETURN
			            NOT ISBLANK ( DtIni )
			                && NOT ISBLANK ( DtRef )
			                && Minutos > LimiteMinutos
			    )
			) + 0
		formatString: 0
		displayFolder: REAVALIACAO
		lineageTag: d64dc5e6-1b0b-4fa0-9424-40e1249dcce8

	measure '% Atend > Tempo reavaliacao' =
			
			VAR LimiteMinutos = COALESCE ( [Valor Meta_reavaliacao], 0 )
			VAR AtendAcima =
			    CALCULATE (
			        COUNT ( reavaliacao[NR_ATENDIMENTO] ),
			        FILTER (
			            reavaliacao,
			            VAR DtIni = reavaliacao[DT_SOLIC_REAVALIACAO]
			            VAR DtEvo = reavaliacao[DT_EVO_PRESC]
			            VAR DtFim = reavaliacao[DT_FIM_REAVALIACAO]
			            VAR DtRef =
			                SWITCH (
			                    TRUE (),
			                    ISBLANK ( DtEvo ) && ISBLANK ( DtFim ), BLANK (),
			                    ISBLANK ( DtEvo ), DtFim,
			                    ISBLANK ( DtFim ), DtEvo,
			                    DtEvo <= DtFim, DtEvo,
			                    DtFim
			                )
			            VAR Minutos = DATEDIFF ( DtIni, DtRef, MINUTE )
			            RETURN
			                NOT ISBLANK ( DtIni )
			                    && NOT ISBLANK ( DtRef )
			                    && Minutos > LimiteMinutos
			        )
			    )
			VAR TotalAtend =
			    CALCULATE (
			        COUNT ( reavaliacao[NR_ATENDIMENTO] ),
			        FILTER (
			            reavaliacao,
			            NOT ISBLANK ( reavaliacao[DT_SOLIC_REAVALIACAO] )
			                && (
			                    NOT ISBLANK ( reavaliacao[DT_EVO_PRESC] )
			                        || NOT ISBLANK ( reavaliacao[DT_FIM_REAVALIACAO] )
			                )
			        )
			    )
			RETURN
			DIVIDE ( AtendAcima, TotalAtend, 0 )
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: REAVALIACAO
		lineageTag: 531c30e4-8524-4901-8d58-eb35811dbd4c

