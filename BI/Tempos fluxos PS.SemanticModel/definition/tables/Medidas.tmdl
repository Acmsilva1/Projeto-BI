	measure 'Qtd Atend > Tempo dispensação' =
			
			VAR LimiteMinutos = COALESCE( [Valor Meta_medicacao], 0 )   -- medida do parâmetro
			RETURN
			CALCULATE (
			    COUNT ( medicacao[NR_ATENDIMENTO] ),
			    KEEPFILTERS ( medicacao[gera_lote] = "S" ),
			    FILTER (
			        medicacao,
			        NOT ISBLANK ( medicacao[MIN_SOLIC_X_DISPENSACAO] )
			            && medicacao[MIN_SOLIC_X_DISPENSACAO] >= 0
			            && medicacao[MIN_SOLIC_X_DISPENSACAO] > LimiteMinutos
			    )
			)
		formatString: 0
		displayFolder: MEDICACOES
		lineageTag: 88a97e82-92c9-4419-9300-6bbbfc6cd884

	measure 'Qtd Atend > Tempo checagem' =
			
			VAR LimiteMinutos = COALESCE( [Valor Meta_medicacao], 0 )   -- medida do parâmetro
			RETURN
			CALCULATE (
			    COUNT ( medicacao[NR_ATENDIMENTO] ),
			    KEEPFILTERS ( medicacao[gera_lote] = "S" ),
			    FILTER (
			        medicacao,
			        NOT ISBLANK ( medicacao[MIN_DISP_X_CHECAGEM] )
			            && medicacao[MIN_DISP_X_CHECAGEM] >= 0
			            && medicacao[MIN_DISP_X_CHECAGEM] > LimiteMinutos
			    )
			)
		formatString: 0
		displayFolder: MEDICACOES
		lineageTag: acdd694c-cdfe-4674-b116-176a09f2a7b2

	measure '% Atend > meta medicacoes' = ```
			
			VAR LimiteMinutos = COALESCE ( [Valor Meta_medicacao], 0 )
			VAR Sel = VALUE ( SELECTEDVALUE ( 'Parametro medicacoes fora da meta'[Order], -1 ) )
			
			VAR AtendAcima =
			    SWITCH (
			        Sel,
			        // 0 = Prescr. x dispensação (com lote)
			        0,
			            CALCULATE (
			                COUNT ( medicacao[NR_ATENDIMENTO] ),
			                KEEPFILTERS ( medicacao[gera_lote] = "S" ),
			                KEEPFILTERS ( NOT ISBLANK ( medicacao[MIN_SOLIC_X_DISPENSACAO] ) ),
			                KEEPFILTERS ( medicacao[MIN_SOLIC_X_DISPENSACAO] >= 0 ),
			                KEEPFILTERS ( medicacao[MIN_SOLIC_X_DISPENSACAO] > LimiteMinutos )
			            ),
			        // 1 = Dispens. x checagem (com lote)
			        1,
			            CALCULATE (
			                COUNT ( medicacao[NR_ATENDIMENTO] ),
			                KEEPFILTERS ( medicacao[gera_lote] = "S" ),
			                KEEPFILTERS ( NOT ISBLANK ( medicacao[MIN_DISP_X_CHECAGEM] ) ),
			                KEEPFILTERS ( medicacao[MIN_DISP_X_CHECAGEM] >= 0 ),
			                KEEPFILTERS ( medicacao[MIN_DISP_X_CHECAGEM] > LimiteMinutos )
			            ),
			        // 2 = Prescr. x checagem (sem lote)
			        2,
			            CALCULATE (
			                COUNT ( medicacao[NR_ATENDIMENTO] ),
			                KEEPFILTERS ( medicacao[gera_lote] <> "S" || ISBLANK ( medicacao[gera_lote] ) ),
			                KEEPFILTERS ( NOT ISBLANK ( medicacao[MINUTOS] ) ),
			                KEEPFILTERS ( medicacao[MINUTOS] >= 0 ),
			                KEEPFILTERS ( medicacao[MINUTOS] > LimiteMinutos )
			            ),
			        // 3 = Prescr. x checagem (todos)
			        3,
			            CALCULATE (
			                COUNT ( medicacao[NR_ATENDIMENTO] ),
			                KEEPFILTERS ( NOT ISBLANK ( medicacao[MINUTOS] ) ),
			                KEEPFILTERS ( medicacao[MINUTOS] >= 0 ),
			                KEEPFILTERS ( medicacao[MINUTOS] > LimiteMinutos )
			            ),
			        BLANK ()
			    )
			
			VAR Denom =
			    SWITCH (
			        Sel,
			        0, [Qtd prescrições com lote],
			        1, [Qtd prescrições com lote],
			        2, [Qtd prescrições sem lote],
			        3, [Qtd_Prescricoes_medicamentos],
			        BLANK ()
