	measure Usuario = ```
			
			VAR _email = USERPRINCIPALNAME()
			VAR _nomeCompleto = LEFT ( _email, SEARCH ( "@", _email ) - 1 )  -- "danilo.rosemberg"
			VAR _primeiroNome = LEFT ( _nomeCompleto, SEARCH ( ".", _nomeCompleto ) - 1 )
			RETURN
			UPPER( LEFT( _primeiroNome, 1 ) ) & LOWER( MID( _primeiroNome, 2, LEN( _primeiroNome ) ) )
			
			```
		displayFolder: OUTROS
		lineageTag: 2a45e252-457e-4d8f-975a-02faaad374a8

