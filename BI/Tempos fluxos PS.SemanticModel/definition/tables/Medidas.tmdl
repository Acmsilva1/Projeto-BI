	measure 'Ícone Var Abs (código)' = ```
			
			VAR v   = [Variação Absoluta Mês]
			VAR dir = [Direção meta (num)]         -- 1 = ↑ é bom | -1 = ↓ é bom
			VAR s   = SIGN(v)                       -- 1 = ↑ | -1 = ↓ | 0 = igual
			VAR bom = (s = dir)
			RETURN
			    SWITCH(
			        TRUE(),
			        ISBLANK(v) || ISBLANK(dir), BLANK(),
			        v = 0, 0,                       -- neutro
			        v > 0 && bom,  2,               -- ↑ verde
			        v < 0 && bom,  1,               -- ↓ verde
			        v > 0 && NOT bom, -1,           -- ↑ vermelho
			        v < 0 && NOT bom, -2            -- ↓ vermelho
			    )
			
			```
		formatString: 0
		displayFolder: METAS
		lineageTag: 9829549b-0d25-4c61-bf36-6dead097b132

	measure 'Qtd Metas Consideradas (Últimos 12M)' = ```
			
			VAR DataFim =
			    MAXX ( ALLSELECTED ( 'Calendario'[Data] ), 'Calendario'[Data] )
			VAR MesFim =
			    DATE ( YEAR ( DataFim ), MONTH ( DataFim ), 1 )
			VAR MesIni =
			    EDATE ( MesFim, -11 )
			
			VAR MesEixo =
			    SELECTEDVALUE ( 'EixoMes'[InicioMes] )
			VAR FimMesEixo =
			    MIN ( EOMONTH ( MesEixo, 0 ), DataFim )
			
			RETURN
			IF (
			    ISBLANK ( DataFim )
			        || ISBLANK ( MesEixo )
			        || MesEixo < MesIni
			        || MesEixo > MesFim,
			    BLANK (),
			    CALCULATE (
			        [Qtd Metas Consideradas],
			        REMOVEFILTERS ( 'Calendario' ),
			        DATESBETWEEN ( 'Calendario'[Data], MesEixo, FimMesEixo )
			    )
			)
			
			```
		formatString: 0
		displayFolder: METAS
		lineageTag: e8446c11-a919-46a9-97d4-ddf549f0f7fb

	measure 'Tooltip Metas Batidas (Últimos 12M)' = ```
			
			VAR b = [Qtd Metas Batidas (Últimos 12M)]
			VAR t = [Qtd Metas Consideradas (Últimos 12M)]
			RETURN
			IF (
