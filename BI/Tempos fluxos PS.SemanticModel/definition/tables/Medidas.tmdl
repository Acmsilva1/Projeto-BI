	measure 'Ind Vol - Bandeira min max 12m RG' = ```
			
			VAR _Ind = SELECTEDVALUE ( 'Dim Indicadores Volume'[Indicador] )
			
			VAR _UsaOriginal =
			    _Ind = "Triagem acima da meta"
			        || _Ind = "Consulta acima da meta"
			        || _Ind = "Medicação acima da meta"
			        || _Ind = "Reavaliação acima da meta"
			        || _Ind = "Permanência acima da meta"
			
			VAR _Un = SELECTEDVALUE ( fluxo[UNIDADE], "__TOTAL__" )
			VAR _Dir = [_Ind Vol - Direção num (por indicador)]
			
			VAR _EhSemana =
			    ISINSCOPE ( 'Calendario'[Semana (rótulo)] )
			
			VAR _EhMes =
			    ISINSCOPE ( 'Calendario'[Mes e Ano] ) && NOT _EhSemana
			
			VAR _EhTotal =
			    NOT _EhSemana && NOT _EhMes
			
			VAR _Tol = 0.0000001
			VAR _VAtual = [Valor Indicador Volume RG]
			VAR _DataRef = [Data última atualização]
			
			RETURN
			    IF (
			        _UsaOriginal,
			        [Ind Vol - Bandeira min max 12m],
			        IF (
			            ISBLANK ( _Ind ) || ISBLANK ( _VAtual ) || _EhTotal || ISBLANK ( _Dir ) || ISBLANK ( _DataRef ),
			            BLANK (),
			            IF (
			                _EhMes,
			                VAR _YmAtual = MAX ( 'Calendario'[Ano Mes Num] )
			
			                VAR _DataFimRef =
			                    EOMONTH ( _DataRef, -1 )
			
			                VAR _YmFim =
			                    YEAR ( _DataFimRef ) * 100 + MONTH ( _DataFimRef )
			
			                VAR _NumFim =
			                    INT ( _YmFim / 100 ) * 12 + MOD ( _YmFim, 100 )
			
			                VAR _NumIni =
			                    _NumFim - 11
			
			                VAR _NumAtual =
			                    INT ( _YmAtual / 100 ) * 12 + MOD ( _YmAtual, 100 )
			
			                VAR _EstaNaJanela =
			                    _NumAtual >= _NumIni && _NumAtual <= _NumFim
			
			                VAR _Base =
			                    FILTER (
			                        'RG Cache Mes Unidade',
			                        'RG Cache Mes Unidade'[Indicador] = _Ind
			                            && 'RG Cache Mes Unidade'[Unidade] = _Un
			                            && INT ( 'RG Cache Mes Unidade'[AnoMesNum] / 100 ) * 12
			                                + MOD ( 'RG Cache Mes Unidade'[AnoMesNum], 100 ) >= _NumIni
			                            && INT ( 'RG Cache Mes Unidade'[AnoMesNum] / 100 ) * 12
			                                + MOD ( 'RG Cache Mes Unidade'[AnoMesNum], 100 ) <= _NumFim
			                            && NOT ISBLANK ( 'RG Cache Mes Unidade'[Valor] )
			                    )
			
			                VAR _MinV =
			                    MINX ( _Base, 'RG Cache Mes Unidade'[Valor] )
			
			                VAR _MaxV =
			                    MAXX ( _Base, 'RG Cache Mes Unidade'[Valor] )
			
			                VAR _YmMin =
			                    MINX (
			                        FILTER ( _Base, ABS ( 'RG Cache Mes Unidade'[Valor] - _MinV ) <= _Tol ),
			                        'RG Cache Mes Unidade'[AnoMesNum]
			                    )
			
			                VAR _YmMax =
			                    MINX (
			                        FILTER ( _Base, ABS ( 'RG Cache Mes Unidade'[Valor] - _MaxV ) <= _Tol ),
			                        'RG Cache Mes Unidade'[AnoMesNum]
			                    )
			
			                VAR _PiorValor =
			                    IF ( _Dir = 1, _MinV, _MaxV )
			
			                VAR _MelhorValor =
			                    IF ( _Dir = 1, _MaxV, _MinV )
			
			                VAR _YmPior =
			                    IF ( _Dir = 1, _YmMin, _YmMax )
			
			                VAR _YmMelhor =
			                    IF ( _Dir = 1, _YmMax, _YmMin )
			
			                RETURN
			                    IF (
			                        NOT _EstaNaJanela
			                            || ISBLANK ( _MinV )
			                            || ISBLANK ( _MaxV )
			                            || ABS ( _MinV - _MaxV ) <= _Tol,
			                        BLANK (),
			                        SWITCH (
			                            TRUE (),
			                            _YmAtual = _YmPior && ABS ( _VAtual - _PiorValor ) <= _Tol, 2,
			                            _YmAtual = _YmMelhor && ABS ( _VAtual - _MelhorValor ) <= _Tol, 1,
			                            BLANK ()
			                        )
			                    ),
			                VAR _SemAtual = MAX ( 'Calendario'[Semana Início] )
			
			                VAR _SemFimRef =
			                    MAXX (
			                        FILTER (
			                            ALL ( 'Calendario' ),
			                            'Calendario'[Semana Fim] < _DataRef
			                        ),
			                        'Calendario'[Semana Início]
			                    )
			
			                VAR _DataIni =
			                    _SemFimRef - 7 * 51
			
			                VAR _EstaNaJanela =
			                    _SemAtual >= _DataIni && _SemAtual <= _SemFimRef
			
			                VAR _Base =
			                    FILTER (
			                        'RG Cache Semana Unidade',
			                        'RG Cache Semana Unidade'[Indicador] = _Ind
			                            && 'RG Cache Semana Unidade'[Unidade] = _Un
			                            && 'RG Cache Semana Unidade'[SemanaInicio] >= _DataIni
			                            && 'RG Cache Semana Unidade'[SemanaInicio] <= _SemFimRef
			                            && NOT ISBLANK ( 'RG Cache Semana Unidade'[Valor] )
			                    )
			
			                VAR _MinV =
			                    MINX ( _Base, 'RG Cache Semana Unidade'[Valor] )
			
			                VAR _MaxV =
			                    MAXX ( _Base, 'RG Cache Semana Unidade'[Valor] )
			
			                VAR _SemMin =
			                    MINX (
			                        FILTER ( _Base, ABS ( 'RG Cache Semana Unidade'[Valor] - _MinV ) <= _Tol ),
			                        'RG Cache Semana Unidade'[SemanaInicio]
			                    )
			
			                VAR _SemMax =
			                    MINX (
			                        FILTER ( _Base, ABS ( 'RG Cache Semana Unidade'[Valor] - _MaxV ) <= _Tol ),
			                        'RG Cache Semana Unidade'[SemanaInicio]
			                    )
			
			                VAR _PiorValor =
			                    IF ( _Dir = 1, _MinV, _MaxV )
			
			                VAR _MelhorValor =
			                    IF ( _Dir = 1, _MaxV, _MinV )
			
			                VAR _SemPior =
			                    IF ( _Dir = 1, _SemMin, _SemMax )
			
			                VAR _SemMelhor =
			                    IF ( _Dir = 1, _SemMax, _SemMin )
			
			                RETURN
			                    IF (
			                        NOT _EstaNaJanela
			                            || ISBLANK ( _SemFimRef )
			                            || ISBLANK ( _MinV )
			                            || ISBLANK ( _MaxV )
			                            || ABS ( _MinV - _MaxV ) <= _Tol,
			                        BLANK (),
			                        SWITCH (
			                            TRUE (),
			                            _SemAtual = _SemPior && ABS ( _VAtual - _PiorValor ) <= _Tol, 2,
			                            _SemAtual = _SemMelhor && ABS ( _VAtual - _MelhorValor ) <= _Tol, 1,
			                            BLANK ()
			                        )
			                    )
			            )
			        )
			    )
			
			```
