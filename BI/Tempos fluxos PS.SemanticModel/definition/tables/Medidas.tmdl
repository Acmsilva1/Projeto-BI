	measure '% Atend > Tempo consulta (0)' =
			
			VAR LimiteMinutos = COALESCE( Meta_consulta[Valor Meta_consulta], 0 )
			VAR TotalAtend    = COUNT ( fluxo[NR_ATENDIMENTO] )
			VAR AtendAcima =
			    CALCULATE (
			        COUNT ( fluxo[NR_ATENDIMENTO] ),
			        FILTER ( fluxo, fluxo[MIN_ENTRADA_X_CONSULTA] > LimiteMinutos )
			    )
			RETURN
			IF (
			    TotalAtend = 0 || ISBLANK(TotalAtend),
			    BLANK(),                                  -- sem atendimentos: fica em branco
			    DIVIDE ( AtendAcima, TotalAtend, 0 ) + 0     -- com atendimentos: 0%, 25%, etc.
			)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: CONSULTA
		lineageTag: 3c9407e8-c9fd-403d-90e2-c99442ce56b3

	measure '% Atend > Tempo alta (0)' =
			
			VAR LimiteMinutos = COALESCE( Meta_alta[Valor Meta_alta], 0 )
			VAR TotalAtend    = COUNT ( fluxo[NR_ATENDIMENTO] )
			VAR AtendAcima =
			    CALCULATE (
			        COUNT ( fluxo[NR_ATENDIMENTO] ),
			        KEEPFILTERS ( fluxo[MIN_ENTRADA_X_ALTA] > LimiteMinutos )
			    )
			RETURN
			IF ( TotalAtend = 0, BLANK(), DIVIDE ( AtendAcima, TotalAtend, 0 ) + 0)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: ALTA
		lineageTag: 58e7b8df-9cc1-44bb-9cef-5a48e0575e46

