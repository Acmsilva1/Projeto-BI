			       NOT ( Vias_medicamentos[CD_MATERIAL] IN { 84278, 84288, 84153, 84271 }) -- Não considera: Cloreto De Sodio 0,9% (10ml), Soro Fisiologico (100ml e 250ml),  Agua Para Injecao (10ml)
			       
			    )
			)
			
			
