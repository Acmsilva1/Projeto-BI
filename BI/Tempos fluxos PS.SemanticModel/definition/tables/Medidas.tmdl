	measure 'Cor Txt Ind Volume - (mês anterior) RG' = ```
			
			VAR _Ind = SELECTEDVALUE ( 'Dim Indicadores Volume'[Indicador] )
			VAR _EhColunaTotal =
			    NOT ISINSCOPE ( 'Calendario'[Mes e Ano] )
			        && NOT ISINSCOPE ( 'Calendario'[Semana (rótulo)] )
			RETURN
			    IF (
			        ISBLANK ( _Ind ) || NOT _EhColunaTotal,
			        BLANK (),
			        VAR _Ym = MAX ( 'Calendario'[Ano Mes Num] )
			        VAR _Y = INT ( _Ym / 100 )
			        VAR _MesNum = MOD ( _Ym, 100 )
			        VAR _PrevYm =
			            IF ( _MesNum = 1, ( _Y - 1 ) * 100 + 12, _Ym - 1 )
			        VAR _DentroMesAnterior =
			            CALCULATE (
			                [_Ind Vol - Dentro meta RG],
			                TREATAS ( { _PrevYm }, 'Calendario'[Ano Mes Num] ),
			                REMOVEFILTERS (
			                    'Calendario'[Mes e Ano],
			                    'Calendario'[Data],
			                    'Calendario'[Semana (rótulo)]
			                )
			            )
			        RETURN
			            SWITCH (
			                TRUE (),
			                ISBLANK ( _DentroMesAnterior ), "#6B7280",
			                _DentroMesAnterior, "#49A455",
			                "#FF0000"
			            )
			    )
			
			```
