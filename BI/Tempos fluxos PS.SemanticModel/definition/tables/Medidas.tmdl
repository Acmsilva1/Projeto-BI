	measure 'Média tempo_entrada_x_internacao (seg)' = ```
			
			CALCULATE(
			    AVERAGEX(
			        FILTER(
			            fluxo,
			            NOT ISBLANK(fluxo[dt_entrada]) &&
			            NOT ISBLANK(fluxo[dt_internacao]) &&
			            fluxo[dt_internacao] >= fluxo[dt_entrada]
			        ),
			        DATEDIFF(fluxo[dt_entrada], fluxo[dt_internacao], SECOND)
			    ),
			    USERELATIONSHIP('Calendario'[Data], fluxo[DT_INTERNACAO_DATA])
			)
			
			```
		displayFolder: CONVERSAO
		lineageTag: 3306a92c-2eb5-4eac-a713-92c7bafa9c93

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '% conversao' =
			
			VAR Numerador =
			    CALCULATE(
			        COUNT(fluxo[NR_ATENDIMENTO]),
			        fluxo[DESTINO] = "Internado",
			        USERELATIONSHIP('Calendario'[Data], fluxo[DT_INTERNACAO_DATA])
			    )
			VAR Denominador =
			    CALCULATE(
			        COUNT(fluxo[NR_ATENDIMENTO]),
			        USERELATIONSHIP('Calendario'[Data], fluxo[DATA])
			    )
			RETURN
			DIVIDE(Numerador, Denominador)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: CONVERSAO
		lineageTag: 8bec6a36-548a-4e83-9597-cc4bd820256d

