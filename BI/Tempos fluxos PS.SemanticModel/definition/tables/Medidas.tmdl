	measure '%Metas Batidas (Últimos 12M)' = ```
			
			VAR DataFim =
			    MAXX ( ALLSELECTED ( 'Calendario'[Data] ), 'Calendario'[Data] )
			VAR MesFim =
			    DATE ( YEAR ( DataFim ), MONTH ( DataFim ), 1 )
			VAR MesIni =
			    EDATE ( MesFim, -11 )
			
			VAR MesEixo =
			    SELECTEDVALUE ( 'EixoMes'[InicioMes] )
			VAR FimMesEixo =
			    MIN ( EOMONTH ( MesEixo, 0 ), DataFim )
			
			-- garante que só desenha mês com movimento (senão dá 100% falso)
			VAR TemDadosNoMes =
			    CALCULATE (
			        COUNTROWS ( 'fluxo' ),
			        REMOVEFILTERS ( 'Calendario' ),
			        DATESBETWEEN ( 'Calendario'[Data], MesEixo, FimMesEixo )
			    )
			
			RETURN
			IF (
			    ISBLANK ( DataFim )
			        || ISBLANK ( MesEixo )
			        || MesEixo < MesIni
			        || MesEixo > MesFim
			        || TemDadosNoMes = 0,
			    BLANK (),
			    CALCULATE (
			        [%Metas Batidas],
			        REMOVEFILTERS ( 'Calendario' ),
			        DATESBETWEEN ( 'Calendario'[Data], MesEixo, FimMesEixo )
			    )
			)
			
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: METAS
		lineageTag: 00a1a360-9b7c-4c22-b46f-08ce52df94e0

