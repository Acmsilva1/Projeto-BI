	measure '_Ind Vol - Valor período anterior (cálculo)' = ```
			
			VAR _Ind =
			    SELECTEDVALUE ( 'Dim Indicadores Volume'[Indicador] )
			
			VAR _EhColunaTotal =
			    ( NOT ISINSCOPE ( 'Calendario'[Mes e Ano] )
			        && NOT ISINSCOPE ( 'Calendario'[Semana (rótulo)] ) )
			        || ( NOT HASONEVALUE ( 'Calendario'[Mes e Ano] )
			            && NOT HASONEVALUE ( 'Calendario'[Semana (rótulo)] ) )
			
			VAR _IsWeek =
			    ISINSCOPE ( 'Calendario'[Semana (rótulo)] )
			
			VAR _UmMesSo =
			    ISINSCOPE ( 'Calendario'[Mes e Ano] )
			        && NOT _IsWeek
			
			VAR _IniSem =
			    MAX ( 'Calendario'[Semana Início] )
			
			VAR _PrevIni =
			    _IniSem - 7
			
			VAR _VPrevSem =
			    CALCULATE (
			        [Valor Indicador Volume],
			        REMOVEFILTERS ( 'Calendario' ),
			        TREATAS ( { _PrevIni }, 'Calendario'[Semana Início] )
			    )
			
			VAR _Ym =
			    MAX ( 'Calendario'[Ano Mes Num] )
			
			VAR _Y =
			    INT ( _Ym / 100 )
			
			VAR _M =
			    MOD ( _Ym, 100 )
			
			VAR _PrevYm =
			    IF ( _M = 1, ( _Y - 1 ) * 100 + 12, _Ym - 1 )
			
			VAR _VPrevMes =
			    CALCULATE (
			        [Valor Indicador Volume],
			        REMOVEFILTERS ( 'Calendario' ),
			        TREATAS ( { _PrevYm }, 'Calendario'[Ano Mes Num] )
			    )
			
			VAR _EndYmVis =
			    MAX ( 'Calendario'[Ano Mes Num] )
			
			VAR _YTot =
			    INT ( _EndYmVis / 100 )
			
			VAR _MTot =
			    MOD ( _EndYmVis, 100 )
			
			VAR _PrevYmTot =
			    IF ( _MTot = 1, ( _YTot - 1 ) * 100 + 12, _EndYmVis - 1 )
			
			VAR _VPrevColunaTotal =
			    CALCULATE (
			        [Valor Indicador Volume],
			        REMOVEFILTERS ( 'Calendario' ),
			        TREATAS ( { _PrevYmTot }, 'Calendario'[Ano Mes Num] )
			    )
			
			RETURN
			    IF (
			        ISBLANK ( _Ind ),
			        BLANK (),
			        IF (
			            _EhColunaTotal,
			            IF ( ISBLANK ( _EndYmVis ), BLANK (), _VPrevColunaTotal ),
			            IF ( _IsWeek, _VPrevSem, IF ( _UmMesSo, _VPrevMes, BLANK () ) )
			        )
			    )
			
			```
		lineageTag: 33660124-d607-43c3-af84-0b7c7085568e

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Ind Vol - Alerta estatístico var' = ```
			
			VAR _Ind =
			    SELECTEDVALUE ( 'Dim Indicadores Volume'[Indicador] )
			
			VAR _DeltaAtual =
			    [Ind Vol - Var absoluta (número)]
			
			VAR _EhTotal =
			    NOT ISINSCOPE ( 'Calendario'[Mes e Ano] )
			        && NOT ISINSCOPE ( 'Calendario'[Semana (rótulo)] )
			
			VAR _EhDesfecho =
			    _Ind = "Desfecho do médico do atend."
			
			VAR _DirecaoMelhor =
			    IF ( _EhDesfecho, 1, -1 )
			
			VAR _Z =
			    [Ind Vol - ZScore Var]
			
			VAR _LimiteSigma =
			    COALESCE (
			        SELECTEDVALUE ( 'Alerta Desv Pad'[Alerta Desv. Pad.] ),
			        2.0
			    )
			
			VAR _Melhora =
			    _DeltaAtual * _DirecaoMelhor > 0
			
			RETURN
			    IF (
			        ISBLANK ( _Ind )
			            || ISBLANK ( _DeltaAtual )
			            || _EhTotal
			            || ISBLANK ( _Z ),
			        BLANK (),
			        SWITCH (
			            TRUE (),
			            ABS ( _Z ) < _LimiteSigma, 0,
			            _Melhora, 1,
			            -1
			        )
			    )
			
			```
		formatString: 0
		lineageTag: 89a5f030-550d-49ad-aee6-1c6251efb795

	measure 'Ind Vol - ZScore Var' = ```
			
			VAR _Ind =
			    SELECTEDVALUE ( 'Dim Indicadores Volume'[Indicador] )
			
			VAR _DeltaAtual =
			    [Ind Vol - Var absoluta (número)]
			
			VAR _EhTotal =
			    NOT ISINSCOPE ( 'Calendario'[Mes e Ano] )
			        && NOT ISINSCOPE ( 'Calendario'[Semana (rótulo)] )
			
			VAR _EhSemana =
			    ISINSCOPE ( 'Calendario'[Semana (rótulo)] )
			
			VAR _EhMes =
			    ISINSCOPE ( 'Calendario'[Mes e Ano] ) && NOT _EhSemana
			
			VAR _SemanaAtual =
			    MAX ( 'Calendario'[Semana Início] )
			
			VAR _FimHistSem =
			    _SemanaAtual - 1
			
			VAR _InicioHistSem =
			    EDATE ( _FimHistSem, -12 ) + 1
			
			VAR _HistoricoSemanas =
			    ADDCOLUMNS (
			        SUMMARIZE (
			            FILTER (
			                ALL ( 'Calendario' ),
			                'Calendario'[Semana Início] >= _InicioHistSem
			                    && 'Calendario'[Semana Início] <= _FimHistSem
			            ),
			            'Calendario'[Semana Início]
			        ),
			        "__Delta",
			            VAR _Sem = 'Calendario'[Semana Início]
			            RETURN
			                CALCULATE (
			                    [Ind Vol - Var absoluta (número)],
			                    REMOVEFILTERS ( 'Calendario' ),
			                    TREATAS ( { _Sem }, 'Calendario'[Semana Início] )
			                )
			    )
			
			VAR _HistoricoSemanasValido =
			    FILTER ( _HistoricoSemanas, NOT ISBLANK ( [__Delta] ) )
			
			VAR _MediaSem =
			    AVERAGEX ( _HistoricoSemanasValido, [__Delta] )
			
			VAR _DpSem =
			    STDEVX.S ( _HistoricoSemanasValido, [__Delta] )
			
			VAR _YmAtual =
			    MAX ( 'Calendario'[Ano Mes Num] )
			
			VAR _AnoAtual =
			    INT ( _YmAtual / 100 )
			
			VAR _MesAtual =
			    MOD ( _YmAtual, 100 )
			
			VAR _YmFimHist =
			    IF ( _MesAtual = 1, ( _AnoAtual - 1 ) * 100 + 12, _YmAtual - 1 )
			
			VAR _NumFimHist =
			    INT ( _YmFimHist / 100 ) * 12 + MOD ( _YmFimHist, 100 )
			
			VAR _NumInicioHist =
			    _NumFimHist - 11
			
			VAR _YmInicioHist =
			    INT ( ( _NumInicioHist - 1 ) / 12 ) * 100 + MOD ( _NumInicioHist - 1, 12 ) + 1
			
			VAR _HistoricoMeses =
			    ADDCOLUMNS (
			        SUMMARIZE (
			            FILTER (
			                ALL ( 'Calendario' ),
			                'Calendario'[Ano Mes Num] >= _YmInicioHist
			                    && 'Calendario'[Ano Mes Num] <= _YmFimHist
			            ),
			            'Calendario'[Ano Mes Num]
			        ),
			        "__Delta",
			            VAR _Ym = 'Calendario'[Ano Mes Num]
			            RETURN
			                CALCULATE (
			                    [Ind Vol - Var absoluta (número)],
			                    REMOVEFILTERS ( 'Calendario' ),
			                    TREATAS ( { _Ym }, 'Calendario'[Ano Mes Num] )
			                )
			    )
			
			VAR _HistoricoMesesValido =
			    FILTER ( _HistoricoMeses, NOT ISBLANK ( [__Delta] ) )
			
			VAR _MediaMes =
			    AVERAGEX ( _HistoricoMesesValido, [__Delta] )
			
			VAR _DpMes =
			    STDEVX.S ( _HistoricoMesesValido, [__Delta] )
			
			VAR _MediaRef =
			    IF ( _EhSemana, _MediaSem, IF ( _EhMes, _MediaMes ) )
			
			VAR _DpRef =
			    IF ( _EhSemana, _DpSem, IF ( _EhMes, _DpMes ) )
			
			RETURN
			    IF (
			        ISBLANK ( _Ind )
			            || ISBLANK ( _DeltaAtual )
			            || _EhTotal
			            || ISBLANK ( _MediaRef )
			            || ISBLANK ( _DpRef )
			            || _DpRef = 0,
			        BLANK (),
			        DIVIDE ( _DeltaAtual - _MediaRef, _DpRef )
			    )
			
			```
		lineageTag: 149d00c2-de03-4417-910e-ea2ad37f3f89

		formatStringDefinition = ```
				"0.00;-0.00;0.00"
				
				```

