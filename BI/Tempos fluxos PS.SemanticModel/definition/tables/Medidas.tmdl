	measure 'Txt Ind Volume célula (valor+meta+var+YTD)' =
			
			VAR _Ind = SELECTEDVALUE ( 'Dim Indicadores Volume'[Indicador] )
			VAR _V = [Valor Indicador Volume]
			VAR _Dentro = [_Ind Vol - Dentro meta]
			VAR _Vp = [_Ind Vol - Valor período anterior]
			VAR _VarPct = [_Ind Vol - Var absoluta vs período ant]
			VAR _YtdPP = [_Ind Vol - YTD diff pp (só última coluna)]
			VAR _FmtNum =
			    SWITCH (
			        TRUE (),
			        _Ind = "Laboratório por paciente" || _Ind = "Medicações por paciente",
			            "#,##0.00",
			        "0.00%"
			    )
			VAR _TxtVal =
			    IF ( ISBLANK ( _V ), "-", SUBSTITUTE ( FORMAT ( _V, _FmtNum ), ".", "," ) )
			VAR _IconMeta = IF ( _Dentro, "🟢", "🔴" )
			VAR _Delta = _V - _Vp
			VAR _Seta =
			    IF ( ISBLANK ( _Vp ), "", IF ( _Delta > 0, "↑", IF ( _Delta < 0, "↓", "→" ) ) )
			VAR _Sinal = IF ( _Delta > 0, "+", "" )
			VAR _VarTxt =
			    IF (
			        ISBLANK ( _VarPct ),
			        "",
			        " | " & _Seta & " " & _Sinal
			            & SUBSTITUTE ( FORMAT ( _VarPct, "0.00%" ), ".", "," )
			    )
			VAR _YtdTxt =
			    IF (
			        ISBLANK ( _YtdPP ),
			        "",
			        " | YTD Δ "
			            & SUBSTITUTE ( FORMAT ( _YtdPP, "+0.00%;-0.00%" ), ".", "," )
			    )
			RETURN
			    IF ( ISBLANK ( _Ind ), BLANK (), _IconMeta & " " & _TxtVal & _VarTxt & _YtdTxt )
		lineageTag: a2a878be-dc9a-4e6b-85ff-68864085802e

