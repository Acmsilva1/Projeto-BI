	measure 'Valor Indicador Volume RG' = ```
			
			VAR _Ind = SELECTEDVALUE ( 'Dim Indicadores Volume'[Indicador] )
			VAR _Un = SELECTEDVALUE ( fluxo[UNIDADE], "__TOTAL__" )
			VAR _EhSemana = ISINSCOPE ( 'Calendario'[Semana (rótulo)] )
			VAR _EhMes = ISINSCOPE ( 'Calendario'[Mes e Ano] ) && NOT _EhSemana
			VAR _EhTotalCol = NOT _EhMes && NOT _EhSemana
			VAR _Sem = MAX ( 'Calendario'[Semana Início] )
			VAR _SemanaFim = MAX ( 'Calendario'[Semana Fim] )
			VAR _UsaAoVivoSemana =
			    _EhSemana && _SemanaFim >= [Data última atualização]
			VAR _Ym = MAX ( 'Calendario'[Ano Mes Num] )
			VAR _ValorSem =
			    LOOKUPVALUE (
			        'RG Cache Semana Unidade'[Valor],
			        'RG Cache Semana Unidade'[Indicador], _Ind,
			        'RG Cache Semana Unidade'[Unidade], _Un,
			        'RG Cache Semana Unidade'[SemanaInicio], _Sem
			    )
			VAR _ValorMes =
			    LOOKUPVALUE (
			        'RG Cache Mes Unidade'[Valor],
			        'RG Cache Mes Unidade'[Indicador], _Ind,
			        'RG Cache Mes Unidade'[Unidade], _Un,
			        'RG Cache Mes Unidade'[AnoMesNum], _Ym
			    )
			RETURN
			    IF (
			        ISBLANK ( _Ind ),
			        BLANK (),
			        SWITCH (
			            TRUE (),
			            _EhTotalCol, [Valor Indicador Volume RG Base],
			            _UsaAoVivoSemana, [Valor Indicador Volume RG Base],
			            _EhSemana, _ValorSem,
			            _EhMes, _ValorMes,
			            [Valor Indicador Volume RG Base]
			        )
			    )
			
			```
