	measure 'Tempo TC/US(sol/chec) por Atendim. (min)' = ```
			
			VAR T =
			    // 1) Agrupa por atendimento
			    SUMMARIZE(
			        'TC e US',
			        'TC e US'[NR_ATENDIMENTO],
			        "DuracaoMin",
			            VAR MinBase =
			                // menor data entre Checagem/Solicitação dentro do atendimento
			                MINX(
			                    'TC e US',
			                    VAR Chec  = 'TC e US'[DT_CHECAGEM]
			                    VAR Solic = 'TC e US'[DT_LIBERACAO]
			                    RETURN
			                        IF(
			                            ISBLANK(Chec),
			                            Solic,   // se não tem checagem, usa solicitação
			                            Chec     // senão, usa checagem
			                        )
			                )
			            VAR MaxLaudo =
			                // maior data de laudo dentro do atendimento
			                MAX('TC e US'[DT_LAUDO])
			            RETURN
			                // 2) Se faltar qualquer data, retorna BLANK (não entra na média)
			                IF(
			                    NOT ISBLANK(MinBase) && NOT ISBLANK(MaxLaudo),
			                    // 3) Diferença em minutos (1440 = 24*60), protegendo contra negativos
			                    MAX(0, INT( (MaxLaudo - MinBase) * 1440 ))
			                )
			    )
			RETURN
			// 4) Média dos minutos por atendimento (BLANKs são ignorados pela AVERAGEX)
			AVERAGEX(T, [DuracaoMin])
			
			```
		displayFolder: TC/US
		lineageTag: 3e644be8-8947-4f45-ae6a-88542cc294e3

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Tempo RX_ECG(solic/chec) por Paciente (min)' = ```
			
			VAR Pacientes =
			    DISTINCT( 'RX e ECG'[NR_ATENDIMENTO] )   // lista de atendimentos no contexto
			RETURN
			AVERAGEX(
			    Pacientes,
			    VAR p = 'RX e ECG'[NR_ATENDIMENTO]       // atendimento atual no iterador
			
			    // menor data entre Checagem/Solicitação dentro do atendimento
			    VAR MinBase =
			        MINX(
			            FILTER( 'RX e ECG', 'RX e ECG'[NR_ATENDIMENTO] = p ),
			            VAR Chec  = 'RX e ECG'[DT_CHECAGEM]
			            VAR Solic = 'RX e ECG'[DT_SOLICITACAO]
			            RETURN
			                IF(
			                    ISBLANK(Chec),
			                    Solic,   // se não tem checagem, usa solicitação
			                    Chec     // senão, usa checagem
			                )
			        )
			
			    // maior data de exame dentro do atendimento
			    VAR MaxExame =
			        CALCULATE(
			            MAX( 'RX e ECG'[DT_EXAME] ),
			            'RX e ECG'[NR_ATENDIMENTO] = p
			        )
			
			    RETURN
			        IF(
			            ISBLANK(MinBase) || ISBLANK(MaxExame),
			            BLANK(),  // se faltar uma das datas, ignora no cálculo
			            MAX( 0, INT( ( MaxExame - MinBase ) * 1440 ) )   // minutos, protegendo contra negativos
			        )
			)
			
			```
		displayFolder: RX/ECG
		lineageTag: 502c1b0f-ef8d-4e4f-a620-dcf9ee35abbf

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '%Metas Batidas' = ```
			
			VAR _MetasSel =
			    VALUES ( 'Param metas de volumes'[Param metas de volumes Pedido] )
			
			VAR _Base =
			    ADDCOLUMNS(
			        _MetasSel,
			        "Real",
			            SWITCH(
			                'Param metas de volumes'[Param metas de volumes Pedido],
			                0, 'Medidas'[% conversao (0)],
			                1, 'Medidas'[% pacientes medicados],
			                2, 'Medidas'[Media medicacoes por pac],
			             --   3, 'Medidas'[% laboratorio (0)],
			                4, 'Medidas'[% pacientes com laborat. (0)],
			                5, 'Medidas'[Media exames lab por pac],
			             --   6, 'Medidas'[% TC (0)],
			                6, 'Medidas'[% pacientes com TC (0)],
			                7, 'Medidas'[Media exames TC por pac],
			                8, 'Medidas'[% Atend > Tempo triagem (0)],
			                9, 'Medidas'[% Atend > Tempo consulta (0)],
			                10, 'Medidas'[% Atend > Tempo medicacao (0)],
			                11, 'Medidas'[% Atend > Tempo reavaliacao (0)],
			                12, 'Medidas'[% Atend > Tempo alta (0)],
			                13, 'Medidas'[% desfecho do médico do atend. (0)]
			                
			
			            ),
			        "Meta",
			            SWITCH(
			                'Param metas de volumes'[Param metas de volumes Pedido],
			                0, 'Meta dinâm volume conversão'[Valor Meta dinâmica volume conversão],
			                1, 'Meta dinâm volume pacs medicados'[Valor Meta dinâm volume pacs medicados],
			                2, 'Meta dinâm volume medicações por pac'[Valor Meta dinâm volume medicações por pac],
			             --   3, 'Meta dinâm volume lab'[Valor Meta dinâm volume lab],
			                4, 'Meta dinâm volume pacs lab'[Valor Meta dinâm volume pacs lab],
			                5, 'Meta dinâm volume laboratorio por pac'[Valor Meta dinâm volume laboratorio por pac],
			             --   6, 'Meta dinâm volume TC'[Valor Meta dinâm volume TC],
			                6, 'Meta dinâm volume pacs TC'[Valor Meta dinâm volume pacs TC],
			                7, 'Valor Meta dinâm volume TC por pac'[Valor Valor Meta dinâm volume TC por pac],
			                8, 'Meta dinâm volume triagem > meta'[Valor Meta dinâm volume triagem > meta],
			                9, 'Meta dinâm volume consulta > meta'[Valor Meta dinâm volume consulta > meta],
			                10, 'Meta dinâm volume medicação > meta'[Valor Meta dinâm volume medicação> meta],
			                11, 'Meta dinâm volume reavaliação > meta'[Valor Meta dinâm volume reavaliação > meta],
			                12, 'Meta dinâm volume permanência > meta'[Valor Meta dinâm volume permanência > meta],
			                13, 'Meta dinâm volume desfecho do médico do atend.'[Valor Meta dinâm volume desfecho do médico do atend.]
			                
			            )
			    )
			
			VAR _Validas =
			    FILTER ( _Base, NOT ISBLANK([Real]) && NOT ISBLANK([Meta]) && [Meta] <> 0 )
			
			VAR _Batidas =
			    SUMX(
			        _Validas,
			        VAR _Id = 'Param metas de volumes'[Param metas de volumes Pedido]
			        RETURN
			            IF(
			                _Id = 13,
			                IF( [Real] >= [Meta], 1, 0 ),   -- 13: maior é melhor
			                IF( [Real] <= [Meta], 1, 0 )    -- demais: menor é melhor
			            )
			    )
			
			RETURN
			DIVIDE( _Batidas, COUNTROWS(_Validas) )
			
			```
		displayFolder: METAS
		lineageTag: 85ac10e5-8b01-4a47-9576-6be3034cf870

		annotation PBI_FormatHint = {"isGeneralNumber":true}

