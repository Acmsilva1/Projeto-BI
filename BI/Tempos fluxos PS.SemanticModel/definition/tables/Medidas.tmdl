			                2, 'Meta dinâm volume medicações por pac'[Valor Meta dinâm volume medicações por pac],
			             --   3, 'Meta dinâm volume lab'[Valor Meta dinâm volume lab],
			                4, 'Meta dinâm volume pacs lab'[Valor Meta dinâm volume pacs lab],
			                5, 'Meta dinâm volume laboratorio por pac'[Valor Meta dinâm volume laboratorio por pac],
			             --   6, 'Meta dinâm volume TC'[Valor Meta dinâm volume TC],
			                7, 'Meta dinâm volume pacs TC'[Valor Meta dinâm volume pacs TC],
			                8, 'Meta dinâm volume triagem > meta'[Valor Meta dinâm volume triagem > meta],
			                9, 'Meta dinâm volume consulta > meta'[Valor Meta dinâm volume consulta > meta],
			                10, 'Meta dinâm volume medicação > meta'[Valor Meta dinâm volume medicação> meta],
			                11, 'Meta dinâm volume reavaliação > meta'[Valor Meta dinâm volume reavaliação > meta],
			                12, 'Meta dinâm volume permanência > meta'[Valor Meta dinâm volume permanência > meta],
			                13, 'Meta dinâm volume desfecho do médico do atend.'[Valor Meta dinâm volume desfecho do médico do atend.],
			                14, 'Valor Meta dinâm volume TC por pac'[Valor Valor Meta dinâm volume TC por pac]
			
			            )
			    )
			
			RETURN
			COUNTROWS( FILTER ( _Base, NOT ISBLANK([Real]) && NOT ISBLANK([Meta]) && [Meta] <> 0 ) )
			
