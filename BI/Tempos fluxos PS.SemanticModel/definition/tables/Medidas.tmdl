	measure 'Cor Txt Ind Volume - Var RG' = ```
			
			VAR _Ind = SELECTEDVALUE ( 'Dim Indicadores Volume'[Indicador] )
			VAR _Un = SELECTEDVALUE ( fluxo[UNIDADE], "__TOTAL__" )
			VAR _EhSemana = ISINSCOPE ( 'Calendario'[Semana (rótulo)] )
			VAR _EhMes = ISINSCOPE ( 'Calendario'[Mes e Ano] ) && NOT _EhSemana
			VAR _EhTotal = NOT _EhSemana && NOT _EhMes
			VAR _Ym = MAX ( 'Calendario'[Ano Mes Num] )
			VAR _Sem = MAX ( 'Calendario'[Semana Início] )
			VAR _AlertaMes =
			    LOOKUPVALUE (
			        'RG Cache Mes Unidade Alertas'[AlertaVar],
			        'RG Cache Mes Unidade Alertas'[Indicador], _Ind,
			        'RG Cache Mes Unidade Alertas'[Unidade], _Un,
			        'RG Cache Mes Unidade Alertas'[AnoMesNum], _Ym
			    )
			VAR _AlertaSem =
			    LOOKUPVALUE (
			        'RG Cache Semana Unidade Alertas'[AlertaVar],
			        'RG Cache Semana Unidade Alertas'[Indicador], _Ind,
			        'RG Cache Semana Unidade Alertas'[Unidade], _Un,
			        'RG Cache Semana Unidade Alertas'[SemanaInicio], _Sem
			    )
			VAR _Alerta =
			    IF ( _EhSemana, _AlertaSem, IF ( _EhMes, _AlertaMes ) )
			RETURN
			    IF (
			        _EhTotal || ISBLANK ( _Ind ),
			        "#6B7280",
			        SWITCH (
			            _Alerta,
			            1, "#5FAE7B",
			            -1, "#D96C6C",
			            "#6B7280"
			        )
			    )
			
			```
