	measure Filtro_Simples_ID =
			
			VAR Sel = SELECTEDVALUE(Filtro_IDs[Medida])  // pega a opção escolhida no slicer
			RETURN
			SWITCH(
			    TRUE(),
			    // Sem nada selecionado OU "(Selecionar Tudo)" -> não filtra (passa tudo)
			    ISBLANK(Sel) || Sel = "(Selecionar Tudo)", 1,
			
			    // Mapeamento da opção do slicer -> medida correspondente (que já retorna 1/0/BLANK)
			    Sel = "Permanência Fora Meta", [ID_PERMANENCIA_FORA_META],
			    Sel = "Consulta Fora Meta",    [ID_CONSULTA_FORA_META],
			    Sel = "Medicação Fora Meta",   [ID_MEDICACAO_FORA_META],
			    Sel = "Reavaliação Fora Meta", [ID_REAVALIACAO_FORA_META],
			    Sel = "RX/ECG Fora Meta",      [ID_RX_ECG_FORA_META],
			    Sel = "TC/US Fora Meta",       [ID_TC_US_FORA_META],
			    Sel = "Triagem Fora Meta",     [ID_TRIAGEM_FORA_META],
			
			    // Fallback de segurança (se vier algum texto fora da lista): não filtra
			    1
			) * 1  // garante 0/1 numérico
		lineageTag: cf99e9fa-f5cf-4683-8382-36bd8cf845db

