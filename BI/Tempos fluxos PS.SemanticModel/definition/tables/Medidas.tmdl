	measure 'Valor metas volumes (Últimos 12M)' = ```
			
			VAR Idx =
			    SELECTEDVALUE ( 'Param metas de volumes'[Param metas de volumes Pedido] )
			
			-- último dia selecionado no slicer (respeita a seleção do calendário)
			VAR DataFim =
			    MAXX ( ALLSELECTED ( 'Calendario'[Data] ), 'Calendario'[Data] )
			
			VAR MesFim =
			    DATE ( YEAR ( DataFim ), MONTH ( DataFim ), 1 )
			
			VAR MesIni =
			    EDATE ( MesFim, -11 )
			
			VAR MesEixo =
			    SELECTEDVALUE ( 'EixoMes'[InicioMes] )
			
			VAR FimMesEixo =
			    MIN ( EOMONTH ( MesEixo, 0 ), DataFim )
			
			RETURN
			IF (
			    ISBLANK ( DataFim )
			        || ISBLANK ( MesEixo )
			        || MesEixo < MesIni
			        || MesEixo > MesFim,
			    BLANK (),
			    CALCULATE (
			        SWITCH (
			            Idx,
			            0, 'Medidas'[% conversao (0)],
			            1, 'Medidas'[% pacientes medicados],
			            2, 'Medidas'[Media medicacoes por pac],
			           -- 3, 'Medidas'[% laboratorio (0)],
			            4, 'Medidas'[% pacientes com laborat. (0)],
			            5, 'Medidas'[Media exames lab por pac],
			           -- 6, 'Medidas'[% TC (0)],
			            7, 'Medidas'[% pacientes com TC (0)],
			            8, 'Medidas'[% Atend > Tempo triagem (0)],
			            9, 'Medidas'[% Atend > Tempo consulta (0)],
			            10, 'Medidas'[% Atend > Tempo medicacao (0)],
			            11, 'Medidas'[% Atend > Tempo reavaliacao],
			            12, 'Medidas'[% Atend > Tempo alta (0)],
			            13, 'Medidas'[% desfecho do médico do atend.],
			            14, 'Medidas'[Media exames TC por pac]
			
			        ),
			        REMOVEFILTERS ( 'Calendario' ),
			        DATESBETWEEN ( 'Calendario'[Data], MesEixo, FimMesEixo )
			    )
			)
			
			```
		displayFolder: METAS
		lineageTag: c0e109ba-323d-4cd8-9c88-4eee8569815b

		formatStringDefinition =
