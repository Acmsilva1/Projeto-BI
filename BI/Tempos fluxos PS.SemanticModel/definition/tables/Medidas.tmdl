			      --  MedidaSelecionada = NAMEOF('Medidas'[% TC (0)]), [% TC (0)],
			        MedidaSelecionada = NAMEOF('Medidas'[% pacientes com TC (0)]), [% pacientes com TC (0)],
			        MedidaSelecionada = NAMEOF('Medidas'[% Atend > Tempo triagem (0)]), [% Atend > Tempo triagem (0)],
			        MedidaSelecionada = NAMEOF('Medidas'[% Atend > Tempo consulta (0)]), [% Atend > Tempo consulta (0)],
			        MedidaSelecionada = NAMEOF('Medidas'[% Atend > Tempo medicacao (0)]), [% Atend > Tempo medicacao (0)],
			        MedidaSelecionada = NAMEOF('Medidas'[% Atend > Tempo reavaliacao (0)]), [% Atend > Tempo reavaliacao (0)],
			        MedidaSelecionada = NAMEOF('Medidas'[% Atend > Tempo alta (0)]), [% Atend > Tempo alta (0)],
			        MedidaSelecionada = NAMEOF('Medidas'[% desfecho do médico do atend. (0)]), [% desfecho do médico do atend. (0)],
			        MedidaSelecionada = NAMEOF('Medidas'[Média diária desfechos (10-16)]), [Média diária desfechos (10-16)],
			        MedidaSelecionada = NAMEOF('Medidas'[Media exames TC por pac]), [Media exames TC por pac],
			        BLANK()
			    )
			
			VAR ValorMesAnterior = [Valor Meta Mês Anterior]
			
			RETURN
			    IF(
			        ISBLANK(ValorAtual) || ISBLANK(ValorMesAnterior),
			        BLANK(),
			        ValorAtual - ValorMesAnterior
			    )
