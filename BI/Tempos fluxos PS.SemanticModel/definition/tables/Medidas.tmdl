	measure 'Dia D-1' = ```
			
			VAR MaxDataAll =
			    CALCULATE ( MAX ( fluxo[DATA] ), ALL (fluxo) )
			VAR DataAnteriorDisponivel =
			    CALCULATE (
			        MAX (fluxo[DATA]),
			        FILTER (ALL(fluxo), fluxo[DATA] < MaxDataAll )
			    )
			RETURN
			    IF (
			        MaxDataAll = TODAY (),
			        DataAnteriorDisponivel,   -- se a última data é hoje, traz o D-1 disponível
			        MaxDataAll                -- se a última data é ontem (ou antes), traz normalmente
			    )
			
			```
