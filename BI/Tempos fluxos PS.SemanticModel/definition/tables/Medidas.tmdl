	measure 'Cor meta volume' = ```
			
			VAR IdSel =
			    SELECTEDVALUE('Param metas de volumes'[Param metas de volumes Pedido]) 
			VAR ValorSel =
			    SWITCH(
			        IdSel,
			        0, [% conversao],
			        1, [% pacientes medicados],
			        2, [Media medicacoes por pac],
			     --   3, [% laboratorio],
			        4, [% pacientes com laborat.],
			        5, [Media exames lab por pac],
			     --   6, [% TC],
			        7, [% pacientes com TC],
			        8, [% Triagem >12min],
			        9, [% Consulta >1:30h],
			        10, [% Medicação >30min],
			        11, [% Reavaliações >45min],
			        12, [% Alta >3h],
			        13, [% desfecho do médico do atend. (0)],
			        14, [Media exames TC por pac]
			    )
			VAR MetaSel =
			    SWITCH(
			        IdSel,
			        0, [Valor Meta dinâmica volume conversão],
			        1, [Valor Meta dinâm volume pacs medicados],
			        2, [Valor Meta dinâm volume medicações por pac],
			     --   3, [Valor Meta dinâm volume lab],
			        4, [Valor Meta dinâm volume pacs lab],
			        5, [Valor Meta dinâm volume laboratorio por pac],
			     --   6, [Valor Meta dinâm volume TC],
			        7, [Valor Meta dinâm volume pacs TC],
			        8, [Valor Meta dinâm volume triagem > meta],
			        9, [Valor Meta dinâm volume consulta > meta],
			        10, [Valor Meta dinâm volume medicação> meta],
			        11, [Valor Meta dinâm volume reavaliação > meta],
			        12, [Valor Meta dinâm volume permanência > meta],
			        13, [Valor Meta dinâm volume desfecho do médico do atend.],
			        14, [Valor Valor Meta dinâm volume TC por pac]
			    )
			VAR IsMaiorMelhor = IdSel = 13
			VAR OK =
			    IF(
			        IsMaiorMelhor,
			        ValorSel >= MetaSel,   -- 13: maior é melhor
			        ValorSel <= MetaSel    -- demais: menor é melhor
			    )
			RETURN
			    IF( OK, "#107C10", "#EC6464" )
			
			```
		displayFolder: METAS
		lineageTag: 50323fbf-413d-42c3-95fe-99d3776a3135

