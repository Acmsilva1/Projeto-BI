			VAR ValorAtual =
			    SWITCH(
			        TRUE(),
			        MedidaSelecionada = NAMEOF('Medidas'[% conversao (0)]), [% conversao (0)],
			        MedidaSelecionada = NAMEOF('Medidas'[% pacientes medicados]), [% pacientes medicados],
			        MedidaSelecionada = NAMEOF('Medidas'[Media medicacoes por pac]), [Media medicacoes por pac],
			      --  MedidaSelecionada = NAMEOF('Medidas'[% laboratorio (0)]), [% laboratorio (0)],
			        MedidaSelecionada = NAMEOF('Medidas'[% pacientes com laborat. (0)]), [% pacientes com laborat. (0)],
