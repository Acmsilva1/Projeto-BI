	measure 'Txt Ind Volume - (mês anterior)' =
			
			VAR _Ind = SELECTEDVALUE ( 'Dim Indicadores Volume'[Indicador] )
			
			// Total da matriz no eixo colunas (funciona com 1 mês no slicer)
			VAR _EhColunaTotal =
			    NOT ISINSCOPE ( 'Calendario'[Mes e Ano] )
			        && NOT ISINSCOPE ( 'Calendario'[Semana (rótulo)] )
			
			VAR _FmtValor =
			    SWITCH (
			        TRUE (),
			        _Ind = "Laboratório por paciente" || _Ind = "Medicações por paciente", "#,##0.00",
			        "0.00%"
			    )
			RETURN
			    IF (
			        ISBLANK ( _Ind ) || NOT _EhColunaTotal,
			        BLANK (),
			        VAR _Ym = MAX ( 'Calendario'[Ano Mes Num] )
			        VAR _Y = INT ( _Ym / 100 )
			        VAR _M = MOD ( _Ym, 100 )
			        VAR _PrevYm = IF ( _M = 1, ( _Y - 1 ) * 100 + 12, _Ym - 1 )
			        VAR _VPrevMes =
			            CALCULATE (
			                [Valor Indicador Volume],
			                TREATAS ( { _PrevYm }, 'Calendario'[Ano Mes Num] ),
			                REMOVEFILTERS (
			                    'Calendario'[Mes e Ano],
			                    'Calendario'[Data],
			                    'Calendario'[Semana (rótulo)]
			                )
			            )
			        RETURN
			            IF (
			                ISBLANK ( _VPrevMes ),
			                BLANK (),
			                "(" & SUBSTITUTE ( FORMAT ( _VPrevMes, _FmtValor ), ".", "," ) & ")"
			            )
			    )
		lineageTag: d506a978-6be0-4f68-9b99-972840df52fc

	measure 'Txt Ind Volume - Var' =
			
			VAR _Ind = SELECTEDVALUE ( 'Dim Indicadores Volume'[Indicador] )
			VAR _V = [Valor Indicador Volume]
