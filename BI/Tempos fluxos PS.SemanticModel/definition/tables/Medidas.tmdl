	measure 'Qtd desfechos (Médico desfecho)' =
			
			VAR _PorMedico =
			    CALCULATE (
			        DISTINCTCOUNT ( fluxo[NR_ATENDIMENTO] ),
			        NOT ISBLANK ( fluxo[DT_DESFECHO] ),
			
			        -- DATA: usar DATA_DESFECHO no lugar da data do atendimento
			        CROSSFILTER ( Calendario[Data], fluxo[DATA], NONE ),
			        USERELATIONSHIP ( Calendario[Data], fluxo[DATA_DESFECHO] ),
			
			        -- Médico: usar MEDICO_DESFECHO
			        CROSSFILTER ( DimMedico[Medico], fluxo[MEDICO_ATENDIMENTO], NONE ),
			        USERELATIONSHIP ( DimMedico[Medico], fluxo[MEDICO_DESFECHO] ),
			
			        -- Turno: usar TURNO_DESFECHO
			        CROSSFILTER ( DimTurno[Turno], fluxo[TURNO_ATENDIMENTO], NONE ),
			        USERELATIONSHIP ( DimTurno[Turno], fluxo[TURNO_DESFECHO] )
			    )
			VAR _Total =
			    CALCULATE (
			        DISTINCTCOUNT ( fluxo[NR_ATENDIMENTO] ),
			        NOT ISBLANK ( fluxo[DT_DESFECHO] ),
			        REMOVEFILTERS ( DimMedico ),
			
			        -- DATA: usar DATA_DESFECHO também no total
			        CROSSFILTER ( Calendario[Data], fluxo[DATA], NONE ),
			        USERELATIONSHIP ( Calendario[Data], fluxo[DATA_DESFECHO] ),
			
			        -- Turno: usar TURNO_DESFECHO
			        CROSSFILTER ( DimTurno[Turno], fluxo[TURNO_ATENDIMENTO], NONE ),
			        USERELATIONSHIP ( DimTurno[Turno], fluxo[TURNO_DESFECHO] )
			    )
			RETURN
			IF ( ISINSCOPE ( DimMedico[Medico] ), _PorMedico, _Total ) + 0
		formatString: 0
		displayFolder: ALTA
		lineageTag: 8afcd801-117a-4b6b-90ec-0a898ba10ad2

