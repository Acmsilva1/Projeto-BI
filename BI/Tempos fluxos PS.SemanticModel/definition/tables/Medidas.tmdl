	measure 'Tempo RX_ECG por Paciente (min)' =
			
			VAR Pacientes = DISTINCT( 'RX e ECG'[NR_ATENDIMENTO] )   // lista de pacientes no contexto
			RETURN
			AVERAGEX(
			    Pacientes,
			    VAR p = 'RX e ECG'[NR_ATENDIMENTO]                   // paciente atual no iterador
			    VAR MinSolic =
			        CALCULATE( MIN( 'RX e ECG'[DT_SOLICITACAO] ),
			                   'RX e ECG'[NR_ATENDIMENTO] = p )      // menor solicitação do paciente
			    VAR MaxExame =
			        CALCULATE( MAX( 'RX e ECG'[DT_EXAME] ),
			                   'RX e ECG'[NR_ATENDIMENTO] = p )      // maior exame do paciente
			    RETURN
			        IF(
			            ISBLANK(MinSolic) || ISBLANK(MaxExame),
			            BLANK(),                                  // se faltar uma das datas, ignora no cálculo
			            INT( ( MaxExame - MinSolic ) * 1440 )     // minutos (1440 = 24*60)
			            // Se quiser evitar negativos por dados invertidos, use:
			            // MAX( 0, INT( ( MaxExame - MinSolic ) * 1440 ) )
			        )
			)
		displayFolder: RX/ECG
		lineageTag: baa0051a-de9d-42cf-b761-917599bb7f8f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Tempo TC/US por Atendimento (min)' = ```
			
			VAR T =
			    // 1) Agrupa por atendimento e calcula min(DT_REALIZADO) e max(DT_LAUDO)
			    SUMMARIZE(
			        'TC e US',
			        'TC e US'[NR_ATENDIMENTO],
			        "DuracaoMin",
			            VAR MinRealizado = MIN('TC e US'[DT_LIBERACAO])
			            VAR MaxLaudo     = MAX('TC e US'[DT_LAUDO])
			            RETURN
			                // 2) Se faltar qualquer data, retorna BLANK (não entra na média)
			                IF(
			                    NOT ISBLANK(MinRealizado) && NOT ISBLANK(MaxLaudo),
			                    // 3) Diferença em minutos (1440 = 24*60), protegendo contra negativos
			                    MAX(0, INT( (MaxLaudo - MinRealizado) * 1440 ))
			                )
			    )
			RETURN
			// 4) Média dos minutos por atendimento (BLANKs são ignorados pela AVERAGEX)
			AVERAGEX(T, [DuracaoMin])
			
			
			```
		displayFolder: TC/US
		lineageTag: 654e71be-d213-4201-befe-8179e0d16234

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Tempo Vias (AGO) por Prescrição (min)' = ```
			
			VAR T =
			    // 1) Mantém filtros externos e restringe às linhas válidas (AGO + datas não nulas)
			    ADDCOLUMNS(
			        SUMMARIZE(
			            FILTER(
			                Vias_medicamentos,
			                Vias_medicamentos[CD_INTERVALO] = "AGO"
			                    && NOT ISBLANK( Vias_medicamentos[DT_LIBERACAO] )
			                    && NOT ISBLANK( Vias_medicamentos[DT_FIM_HORARIO] )
			            ),
			            Vias_medicamentos[NR_PRESCRICAO]        // agrupa por prescrição
			        ),
			        "DuracaoMin",
			            VAR MinLib = CALCULATE( MIN( Vias_medicamentos[DT_LIBERACAO] ) )
			            VAR MaxFim = CALCULATE( MAX( Vias_medicamentos[DT_FIM_HORARIO] ) )
			            RETURN
			                // Diferença em minutos; proteje contra negativos por segurança
			                MAX( 0, INT( ( MaxFim - MinLib ) * 1440 ) )
			    )
			RETURN
			// 2) Média das durações por prescrição (BLANKs/sem linhas => retorna BLANK)
			AVERAGEX( T, [DuracaoMin] )
			
			
			```
		displayFolder: MEDICACOES
		lineageTag: b577309f-139b-48f4-8759-1ba3966e1308

