		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Média tempo triagem' =
			
			VAR TotalMinutos = AVERAGE(fluxo[MIN_ENTRADA_X_TRIAGEM])
			VAR Horas = QUOTIENT(TotalMinutos, 60)
			VAR Minutos = MOD(TotalMinutos, 60)
			VAR Segundos = ROUND(60 * (TotalMinutos - FLOOR(TotalMinutos, 1)), 0)
			RETURN
			    FORMAT(Horas, "00") & ":" & FORMAT(Minutos, "00") & ":" & FORMAT(Segundos, "00")
