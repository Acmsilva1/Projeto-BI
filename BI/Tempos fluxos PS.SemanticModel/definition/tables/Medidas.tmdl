	measure 'Qtd desfechos (10-16 | dt_desfecho)' = ```
			
			CALCULATE (
			    [Qtd desfechos],  -- DISTINCTCOUNT NR_ATENDIMENTO com DT_DESFECHO preenchida
			
			    -- Hora 10–16 (desfecho)
			    USERELATIONSHIP ( fluxo[HR_DESFECHO], Horas[HORAS] ),
			    Horas[Plantao_6h(10h-16h)] = 1,
			
			    -- Data do desfecho (em vez da data do atendimento)
			    CROSSFILTER ( Calendario[Data], fluxo[DATA], NONE ),
			    USERELATIONSHIP ( Calendario[Data], fluxo[DATA_DESFECHO] )
			)
			
			```
