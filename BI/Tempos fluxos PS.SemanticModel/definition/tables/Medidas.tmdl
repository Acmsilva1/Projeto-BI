	measure '% Atend > Tempo triagem (RG fixo)' = ```
			
			VAR LimiteMinutos = 12
			VAR TotalAtend = COUNT ( fluxo[NR_ATENDIMENTO] )
			VAR AtendAcima =
			    CALCULATE (
			        COUNT ( fluxo[NR_ATENDIMENTO] ),
			        KEEPFILTERS ( fluxo[MIN_ENTRADA_X_TRIAGEM] > LimiteMinutos )
			    )
			RETURN
			    IF ( TotalAtend = 0, BLANK (), DIVIDE ( AtendAcima, TotalAtend, 0 ) + 0 )
			
