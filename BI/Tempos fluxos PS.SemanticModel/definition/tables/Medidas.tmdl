	measure 'Qtd Atend > Tempo RX' =
			
			VAR LimiteMinutos = Meta_ECG_RX[Valor Tempo Minutos]            -- medida do parâmetro
			RETURN
			CALCULATE (
			    COUNT ( 'RX e ECG'[NR_PRESCRICAO] ),
			    FILTER (
			        'RX e ECG',
			        'RX e ECG'[Diferença Minutos RX_ECG] > LimiteMinutos
			    )
			)
		formatString: 0
		displayFolder: RX/ECG
		lineageTag: 4755861d-286f-4a4d-bdef-dea515f22d65

	measure '% Atend > Tempo RX' = ```
			
			VAR LimiteMinutos = Meta_ECG_RX[Valor Tempo Minutos]
			VAR AtendAcima =
			    CALCULATE (
			        COUNT ( 'RX e ECG'[NR_PRESCRICAO] ),
			        FILTER (
			            'RX e ECG',
			            'RX e ECG'[Diferença Minutos RX_ECG] > LimiteMinutos
			        )
			    )
			VAR TotalAtend =
			    CALCULATE ( COUNT ( 'RX e ECG'[NR_PRESCRICAO] ) )
			RETURN
			DIVIDE ( AtendAcima, TotalAtend, 0 )
			
			```
