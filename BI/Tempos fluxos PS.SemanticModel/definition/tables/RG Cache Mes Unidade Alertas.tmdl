	partition 'RG Cache Mes Unidade Alertas' = calculated
		mode: import
		source = ```
				
				VAR _LimiteSigma = 1.5
				VAR Base =
				    ADDCOLUMNS (
				        'RG Cache Mes Unidade',
				        "Delta",
				            VAR _V = [Valor]
				            VAR _Vp = [ValorAnterior]
				            RETURN
				                IF ( ISBLANK ( _V ) || ISBLANK ( _Vp ), BLANK (), _V - _Vp )
				    )
				RETURN
				    ADDCOLUMNS (
				        Base,
				        "ZScore",
				            VAR _Ind = [Indicador]
				            VAR _Un = [Unidade]
				            VAR _Ym = [AnoMesNum]
				            VAR _NumFim = INT ( _Ym / 100 ) * 12 + MOD ( _Ym, 100 ) - 1
				            VAR _NumIni = _NumFim - 11
				            VAR _BaseHist =
				                FILTER (
				                    Base,
				                    [Indicador] = _Ind
				                        && [Unidade] = _Un
				                        && INT ( [AnoMesNum] / 100 ) * 12 + MOD ( [AnoMesNum], 100 ) >= _NumIni
				                        && INT ( [AnoMesNum] / 100 ) * 12 + MOD ( [AnoMesNum], 100 ) <= _NumFim
				                        && NOT ISBLANK ( [Delta] )
				                )
				            VAR _Media = AVERAGEX ( _BaseHist, [Delta] )
				            VAR _DP = STDEVX.S ( _BaseHist, [Delta] )
				            VAR _Delta = [Delta]
				            RETURN
				                IF (
				                    ISBLANK ( _Delta ) || ISBLANK ( _DP ) || _DP = 0,
				                    BLANK (),
				                    DIVIDE ( _Delta - _Media, _DP )
				                ),
				        "AlertaVar",
				            VAR _Dir =
				                IF ( [Indicador] = "Desfecho do médico do atend.", 1, -1 )
				            VAR _Delta = [Delta]
				            VAR _Ym = [AnoMesNum]
				            VAR _Ind = [Indicador]
				            VAR _Un = [Unidade]
				            VAR _Z =
				                MAXX (
				                    FILTER (
				                        Base,
				                        [Indicador] = _Ind
				                            && [Unidade] = _Un
				                            && [AnoMesNum] = _Ym
				                    ),
				                    BLANK ()
				                )
				            VAR _NumFim = INT ( _Ym / 100 ) * 12 + MOD ( _Ym, 100 ) - 1
				            VAR _NumIni = _NumFim - 11
				            VAR _BaseHist =
				                FILTER (
				                    Base,
				                    [Indicador] = _Ind
				                        && [Unidade] = _Un
				                        && INT ( [AnoMesNum] / 100 ) * 12 + MOD ( [AnoMesNum], 100 ) >= _NumIni
				                        && INT ( [AnoMesNum] / 100 ) * 12 + MOD ( [AnoMesNum], 100 ) <= _NumFim
				                        && NOT ISBLANK ( [Delta] )
				                )
				            VAR _Media = AVERAGEX ( _BaseHist, [Delta] )
				            VAR _DP = STDEVX.S ( _BaseHist, [Delta] )
				            VAR _ZScore =
				                IF (
				                    ISBLANK ( _Delta ) || ISBLANK ( _DP ) || _DP = 0,
				                    BLANK (),
				                    DIVIDE ( _Delta - _Media, _DP )
				                )
				            VAR _Favoravel = _Delta * _Dir > 0
				            RETURN
				                IF (
				                    ISBLANK ( _ZScore ),
				                    0,
				                    IF (
				                        ABS ( _ZScore ) < _LimiteSigma,
				                        0,
				                        IF ( _Favoravel, 1, -1 )
				                    )
				                )
				    )
				
				```

	annotation PBI_Id = 0c736b8802c44c15a1ee6a15d02760ee

