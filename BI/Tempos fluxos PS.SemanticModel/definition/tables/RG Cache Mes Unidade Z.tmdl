	column ZScore
		lineageTag: cac3e3bc-5bab-48a7-9db8-907bbd2cb3e0
		summarizeBy: sum
		isNameInferred
		sourceColumn: [ZScore]

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	partition 'RG Cache Mes Unidade Z' = calculated
		mode: import
		source = ```
				
				ADDCOLUMNS (
				    'RG Cache Mes Unidade Stats',
				    "ZScore",
				        VAR _Ind = [Indicador]
				        VAR _Un = [Unidade]
				        VAR _Ym = [AnoMesNum]
				        VAR _NumFim = INT ( _Ym / 100 ) * 12 + MOD ( _Ym, 100 ) - 1
				        VAR _NumIni = _NumFim - 11
				        VAR _BaseHist =
				            FILTER (
				                'RG Cache Mes Unidade Stats',
				                [Indicador] = _Ind
				                    && [Unidade] = _Un
				                    && INT ( [AnoMesNum] / 100 ) * 12 + MOD ( [AnoMesNum], 100 ) >= _NumIni
				                    && INT ( [AnoMesNum] / 100 ) * 12 + MOD ( [AnoMesNum], 100 ) <= _NumFim
				                    && NOT ISBLANK ( [Delta] )
				            )
				        VAR _Media = AVERAGEX ( _BaseHist, [Delta] )
				        VAR _DP = STDEVX.S ( _BaseHist, [Delta] )
				        VAR _Delta = [Delta]
				        RETURN
				            IF (
				                ISBLANK ( _Delta ) || ISBLANK ( _DP ) || _DP = 0,
				                BLANK (),
				                DIVIDE ( _Delta - _Media, _DP )
				            )
				)
				
				```

	annotation PBI_Id = fda2fc2a9b584064be9595aed0b06011

