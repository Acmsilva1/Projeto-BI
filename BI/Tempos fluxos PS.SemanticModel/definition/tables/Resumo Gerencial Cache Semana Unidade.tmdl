		annotation PBI_FormatHint = {"isGeneralNumber":true}

	partition 'Resumo Gerencial Cache Semana Unidade' = calculated
		mode: import
		source = ```
				
				VAR DataRef =
				    CALCULATE ( MAX ( fluxo[DT_ENTRADA] ), ALL ( fluxo ) )
				VAR DataInicio =
				    EDATE ( DataRef, -24 ) + 1
				VAR Semanas =
				    SUMMARIZE (
				        FILTER (
				            ALL ( 'Calendario' ),
				            'Calendario'[Data] >= DataInicio
				                && 'Calendario'[Data] <= DataRef
				        ),
				        'Calendario'[Semana Início],
				        'Calendario'[Semana (rótulo)],
				        'Calendario'[AnoSemana],
				        'Calendario'[Ano Mes Num]
				    )
				VAR Indicadores =
				    FILTER (
				        VALUES ( 'Dim Indicadores Volume'[Indicador] ),
				        NOT ISBLANK ( 'Dim Indicadores Volume'[Indicador] )
				    )
				VAR Unidades =
				    UNION (
				        ROW ( "UNIDADE", "__TOTAL__" ),
				        DISTINCT (
				            SELECTCOLUMNS (
				                FILTER ( ALL ( fluxo ), NOT ISBLANK ( fluxo[UNIDADE] ) ),
				                "UNIDADE", fluxo[UNIDADE]
				            )
				        )
				    )
				RETURN
				    FILTER (
				        ADDCOLUMNS (
				            CROSSJOIN ( Semanas, Indicadores, Unidades ),
				            "Valor",
				                VAR _Sem = [Semana Início]
				                VAR _Ind = [Indicador]
				                VAR _Un = [UNIDADE]
				                RETURN
				                    IF (
				                        _Un = "__TOTAL__",
				                        CALCULATE (
				                            [Valor Indicador Volume],
				                            TREATAS ( { _Ind }, 'Dim Indicadores Volume'[Indicador] ),
				                            TREATAS ( { _Sem }, 'Calendario'[Semana Início] ),
				                            REMOVEFILTERS ( fluxo[UNIDADE] )
				                        ),
				                        CALCULATE (
				                            [Valor Indicador Volume],
				                            TREATAS ( { _Ind }, 'Dim Indicadores Volume'[Indicador] ),
				                            TREATAS ( { _Sem }, 'Calendario'[Semana Início] ),
				                            TREATAS ( { _Un }, fluxo[UNIDADE] )
				                        )
				                    )
				        ),
				        NOT ISBLANK ( [Valor] )
				    )
				
				```

	annotation PBI_Id = 797e92e3822d4963941ee47f4b176615

