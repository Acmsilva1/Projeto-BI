{
  "name": "hospital_bi_mvc",
  "version": "2.0.0",
  "type": "module",
  "description": "Hospital BI — React + API Node (TypeScript)",
  "scripts": {
    "dev": "concurrently -k \"npm run api\" \"npm run vite:wait\"",
    "vite:wait": "node ../BACKEND/web-dev/wait-api.cjs && vite",
    "vite": "vite",
    "api": "npm run dev --prefix ../BACKEND",
    "build": "vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^8.2.2",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.7"
  },
  "dependencies": {
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
