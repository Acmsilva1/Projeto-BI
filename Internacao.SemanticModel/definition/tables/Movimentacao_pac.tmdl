	column CLASSIFICACAO
		dataType: string
		lineageTag: 56bfb597-a3bf-4c59-9241-1d9a47ecf32a
		summarizeBy: none
		sourceColumn: CLASSIFICACAO

		annotation SummarizationSetBy = Automatic

	column UTI_Alta_Evento =
			
			VAR ClassAtual = TRIM(UPPER(Movimentacao_pac[CLASSIFICACAO]))
			VAR ProxClass  = TRIM(UPPER(Movimentacao_pac[ProxClassMov]))
			RETURN
			IF(
			    ClassAtual IN { "UTI", "UPC", "UTI EXTRA" }
			        && (
			            ISBLANK(Movimentacao_pac[ProxInicioMov])
			            || ISBLANK(ProxClass)
			            || NOT ( ProxClass IN { "UTI", "UPC", "UTI EXTRA" } )
			        ),
			    1,
			    0
			)
		formatString: 0
		lineageTag: a1e5a118-5e35-483a-935c-150ce3fff713
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column ProxEntradaUTI_AposAlta = ```
			
			VAR pid = Movimentacao_pac[NR_ATENDIMENTO]
			VAR saida = Movimentacao_pac[HR_FIM_HISTORICO]
			RETURN
			IF(
			    Movimentacao_pac[UTI_Alta_Evento] = 1
			        && NOT ISBLANK(saida),
			    CALCULATE(
			        MIN(Movimentacao_pac[HR_HISTORICO]),
			        FILTER(
			            ALL(Movimentacao_pac),
			            Movimentacao_pac[NR_ATENDIMENTO] = pid  
			                && Movimentacao_pac[CLASSIFICACAO] IN {"UTI","UPC","UTI EXTRA"}
			                && Movimentacao_pac[HR_HISTORICO] > saida
			        )
			    )
			)
			```
		formatString: General Date
		lineageTag: 6f920f95-bc45-4adf-9b3e-841a40e86c66
		summarizeBy: none

		variation Variation
			isDefault
			relationship: 843bda75-df6e-4486-8c17-f864d46a3cb6
			defaultHierarchy: LocalDateTable_db04c865-7ebc-4d1f-aee2-57613a31586d.'Hierarquia de datas'

		annotation SummarizationSetBy = Automatic

	column ReinternouUTI_48h =
			
			VAR proxUTI = Movimentacao_pac[ProxEntradaUTI_AposAlta]
			VAR saida   = Movimentacao_pac[HR_FIM_HISTORICO]
			RETURN
			IF(
			    Movimentacao_pac[UTI_Alta_Evento] = 1
			        && NOT ISBLANK(saida)
			        && NOT ISBLANK(proxUTI)
			        && proxUTI <= saida + (48/24),
			    1,
			    0
			)
		formatString: 0
		lineageTag: dc64e95a-ddaf-4900-b9e1-ba020b172960
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column UTI_inicio_permanencia =
			
			VAR pid = Movimentacao_pac[NR_ATENDIMENTO]
			VAR fim = Movimentacao_pac[HR_FIM_HISTORICO]
			VAR fimAnterior =
			    CALCULATE(
			        MAX(Movimentacao_pac[HR_FIM_HISTORICO]),
			        FILTER(
			            ALL(Movimentacao_pac),
			            Movimentacao_pac[NR_ATENDIMENTO] = pid
			                && Movimentacao_pac[UTI_Alta_Evento] = 1
			                && Movimentacao_pac[HR_FIM_HISTORICO] < fim
			        )
			    )
			RETURN
			IF(
			    Movimentacao_pac[UTI_Alta_Evento] = 1 && NOT ISBLANK(fim),
			    CALCULATE(
			        MIN(Movimentacao_pac[HR_HISTORICO]),
			        FILTER(
			            ALL(Movimentacao_pac),
			            Movimentacao_pac[NR_ATENDIMENTO] = pid
			                && TRIM(UPPER(Movimentacao_pac[CLASSIFICACAO])) IN { "UTI", "UPC", "UTI EXTRA" }
			                && Movimentacao_pac[HR_HISTORICO] <= fim
			                && ( ISBLANK(fimAnterior) || Movimentacao_pac[HR_HISTORICO] > fimAnterior )
			        )
			    )
			)
		formatString: General Date
		lineageTag: ff35d593-6602-4160-9671-879202ced322
		summarizeBy: none

		variation Variation
			isDefault
			relationship: 0fc4fc4b-c7e3-41ac-a16a-9b995162d163
			defaultHierarchy: LocalDateTable_4944da9f-030a-4a21-b5f4-a94e11f74d8d.'Hierarquia de datas'

		annotation SummarizationSetBy = Automatic

	column UTI_tempo_permanencia_horas =
			
			VAR ini = Movimentacao_pac[UTI_inicio_permanencia]
			VAR fim = Movimentacao_pac[HR_FIM_HISTORICO]
			RETURN
			IF(
			    Movimentacao_pac[UTI_Alta_Evento] = 1
			        && NOT ISBLANK(ini)
			        && NOT ISBLANK(fim),
			    DIVIDE( DATEDIFF(ini, fim, MINUTE), 60 )
			)
		lineageTag: a277f4f8-990e-4bf9-bd7e-362152eba82a
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column UTI_tempo_permanencia_dias =
			
			DIVIDE(Movimentacao_pac[UTI_tempo_permanencia_horas], 24)
		lineageTag: 4122f694-3258-44b4-860d-208857b9ca72
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

