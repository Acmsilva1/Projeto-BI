	column ProxInicioMov = ```
			
			VAR pid = Movimentacao_pac[NR_ATENDIMENTO]
			VAR ini = Movimentacao_pac[HR_HISTORICO]
			RETURN
			CALCULATE(
			    MIN(Movimentacao_pac[HR_HISTORICO]),
			    FILTER(
			        ALL(Movimentacao_pac),
			        Movimentacao_pac[NR_ATENDIMENTO] = pid 
			            && Movimentacao_pac[HR_HISTORICO] > ini 
			    )
			)
			```
		formatString: General Date
		lineageTag: f3552ba7-ea01-4901-9299-22dcba8dbb4f
		summarizeBy: none

		variation Variation
			isDefault
			relationship: b296730a-df0b-45d6-9d3d-03433644c94f
			defaultHierarchy: LocalDateTable_7d5c57a6-c497-4411-b8ba-0d5f67288738.'Hierarquia de datas'

		annotation SummarizationSetBy = Automatic

	column ProxClassMov =
			
			VAR pid = Movimentacao_pac[NR_ATENDIMENTO]
			VAR proxIni = Movimentacao_pac[ProxInicioMov]
			RETURN
			CALCULATE(
			    SELECTEDVALUE(Movimentacao_pac[CLASSIFICACAO]),
			    FILTER(
			        ALL(Movimentacao_pac),
			        Movimentacao_pac[NR_ATENDIMENTO] = pid
			            && Movimentacao_pac[HR_HISTORICO] = proxIni
			    )
			)
		lineageTag: 1053aaa7-e0fe-4d83-84b9-6565bdbb43f5
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

