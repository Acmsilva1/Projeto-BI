		isNameInferred
		sourceColumn: [CLASSIFICACAO]

		annotation SummarizationSetBy = Automatic

	partition UTI_Episodios = calculated
		mode: import
		source =
				
				SELECTCOLUMNS(
				    FILTER(
				        Movimentacao_pac,
				        Movimentacao_pac[UTI_Alta_Evento] = 1 &&
				        NOT ISBLANK(Movimentacao_pac[UTI_inicio_permanencia])
				    ),
				    "UNIDADE", Movimentacao_pac[UNIDADE],
				    "NR_ATENDIMENTO", Movimentacao_pac[NR_ATENDIMENTO],
				    "CLASSIFICACAO",
				        VAR pid = Movimentacao_pac[NR_ATENDIMENTO]
				        VAR dtIni = Movimentacao_pac[UTI_inicio_permanencia]
				        RETURN
				            CALCULATE(
				                MAX(Movimentacao_pac[CLASSIFICACAO]),
				                FILTER(
				                    ALL(Movimentacao_pac),
				                    Movimentacao_pac[NR_ATENDIMENTO] = pid &&
				                    Movimentacao_pac[HR_HISTORICO] = dtIni
				                )
				            ),
				    "PROX_CLASSF", Movimentacao_pac[ProxClassMov],
				    "DT_ENTRADA_UTI", Movimentacao_pac[UTI_inicio_permanencia],
				    "DT_SAIDA_UTI", Movimentacao_pac[HR_FIM_HISTORICO],
				    "DIAS_PERMANENCIA_UTI_TOTAL",
				        DATEDIFF(
				            Movimentacao_pac[UTI_inicio_permanencia],
				            Movimentacao_pac[HR_FIM_HISTORICO],
				            DAY
				        )
				)

	annotation PBI_Id = dc1951b58212456983252258279756a5

