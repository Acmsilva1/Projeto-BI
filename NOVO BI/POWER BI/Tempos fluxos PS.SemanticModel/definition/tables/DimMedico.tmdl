table DimMedico
	lineageTag: 848d7e49-8fea-427f-b5d6-232a9a069be1

	column Medico
		lineageTag: b7fa5f11-ac70-4aa8-8e2e-ce6110cfed85
		summarizeBy: none
		isNameInferred
		sourceColumn: [Medico]

		annotation SummarizationSetBy = Automatic

	partition DimMedico = calculated
		mode: import
		source =
				
				DISTINCT (
				    FILTER (
				        UNION (
				            SELECTCOLUMNS ( fluxo, "Medico", fluxo[MEDICO_ATENDIMENTO] ),
				            SELECTCOLUMNS ( fluxo, "Medico", fluxo[MEDICO_DESFECHO] )
				        ),
				        NOT ISBLANK ( [Medico] )
				    )
				)

	annotation PBI_Id = 8c9d45e8b3074b139e8514e74b1a8588

