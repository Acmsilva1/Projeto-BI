	partition 'RG Cache Mes Unidade Stats' = calculated
		mode: import
		source = ```
				
				ADDCOLUMNS (
				    'RG Cache Mes Unidade',
				    "ValorAnterior",
				        VAR _Ind = [Indicador]
				        VAR _Un = [Unidade]
				        VAR _Ym = [AnoMesNum]
				        VAR _Y = INT ( _Ym / 100 )
				        VAR _M = MOD ( _Ym, 100 )
				        VAR _YmPrev = IF ( _M = 1, ( _Y - 1 ) * 100 + 12, _Ym - 1 )
				        RETURN
				            MAXX (
				                FILTER (
				                    'RG Cache Mes Unidade',
				                    'RG Cache Mes Unidade'[Indicador] = _Ind
				                        && 'RG Cache Mes Unidade'[Unidade] = _Un
				                        && 'RG Cache Mes Unidade'[AnoMesNum] = _YmPrev
				                ),
				                'RG Cache Mes Unidade'[Valor]
				            ),
				    "Delta",
				        VAR _V = [Valor]
				        VAR _Ind = [Indicador]
				        VAR _Un = [Unidade]
				        VAR _Ym = [AnoMesNum]
				        VAR _Y = INT ( _Ym / 100 )
				        VAR _M = MOD ( _Ym, 100 )
				        VAR _YmPrev = IF ( _M = 1, ( _Y - 1 ) * 100 + 12, _Ym - 1 )
				        VAR _Vp =
				            MAXX (
				                FILTER (
				                    'RG Cache Mes Unidade',
				                    'RG Cache Mes Unidade'[Indicador] = _Ind
				                        && 'RG Cache Mes Unidade'[Unidade] = _Un
				                        && 'RG Cache Mes Unidade'[AnoMesNum] = _YmPrev
				                ),
				                'RG Cache Mes Unidade'[Valor]
				            )
				        RETURN
				            IF ( ISBLANK ( _V ) || ISBLANK ( _Vp ), BLANK (), _V - _Vp )
				)
				
				```

	annotation PBI_Id = ac3ab93480894f64a53561bcbcbef9ae

