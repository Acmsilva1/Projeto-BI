{
  "watch_roots": [
    "backend",
    "frontend/js",
    "frontend/css",
    "frontend/index.html",
    "frontend/package.json",
    "frontend/vite.config.js",
    "frontend/tailwind.config.js"
  ],
  "ignore_globs": [
    ".git/*",
    "frontend/node_modules/*",
    "frontend/dist/*",
    ".codex-logs/*",
    "logs/*",
    "backend/__pycache__/*",
    "backend/routers/__pycache__/*",
    "backend/models/__pycache__/*",
    "backend/schemas/__pycache__/*",
    "backend/database/__pycache__/*"
  ],
  "scan_files_for_encoding": [
    "backend/server.js",
    "backend/live_service.js",
    "backend/db.js",
    "frontend/js/app.js",
    "frontend/index.html"
  ],
  "encoding_bad_patterns": [
    "Ã¡",
    "Ã¢",
    "Ã£",
    "Ã§",
    "Ã©",
    "Ãª",
    "Ã­",
    "Ã³",
    "Ã´",
    "Ãµ",
    "Ãº",
    "Ã ",
    "Â",
    "ï¿½"
  ],
  "commands": [
    {
      "name": "backend_syntax_server",
      "cmd": ["node", "--check", "backend/server.js"],
      "cwd": "."
    },
    {
      "name": "backend_syntax_live_service",
      "cmd": ["node", "--check", "backend/live_service.js"],
      "cwd": "."
    },
    {
      "name": "backend_syntax_db",
      "cmd": ["node", "--check", "backend/db.js"],
      "cwd": "."
    },
    {
      "name": "frontend_build",
      "cmd": ["npm", "run", "css:build"],
      "cwd": "frontend",
      "timeout_sec": 120
    }
  ]
}
