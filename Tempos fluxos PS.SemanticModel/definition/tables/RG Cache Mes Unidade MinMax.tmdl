	partition 'RG Cache Mes Unidade MinMax' = calculated
		mode: import
		source = ```
				
				ADDCOLUMNS (
				    'RG Cache Mes Unidade',
				    "Min12",
				        VAR _Ind = [Indicador]
				        VAR _Un = [Unidade]
				        VAR _Ym = [AnoMesNum]
				        VAR _NumFim = INT ( _Ym / 100 ) * 12 + MOD ( _Ym, 100 )
				        VAR _NumIni = _NumFim - 11
				        RETURN
				            MINX (
				                FILTER (
				                    'RG Cache Mes Unidade',
				                    [Indicador] = _Ind
				                        && [Unidade] = _Un
				                        && INT ( [AnoMesNum] / 100 ) * 12 + MOD ( [AnoMesNum], 100 ) >= _NumIni
				                        && INT ( [AnoMesNum] / 100 ) * 12 + MOD ( [AnoMesNum], 100 ) <= _NumFim
				                        && NOT ISBLANK ( [Valor] )
				                ),
				                [Valor]
				            ),
				    "Max12",
				        VAR _Ind = [Indicador]
				        VAR _Un = [Unidade]
				        VAR _Ym = [AnoMesNum]
				        VAR _NumFim = INT ( _Ym / 100 ) * 12 + MOD ( _Ym, 100 )
				        VAR _NumIni = _NumFim - 11
				        RETURN
				            MAXX (
				                FILTER (
				                    'RG Cache Mes Unidade',
				                    [Indicador] = _Ind
				                        && [Unidade] = _Un
				                        && INT ( [AnoMesNum] / 100 ) * 12 + MOD ( [AnoMesNum], 100 ) >= _NumIni
				                        && INT ( [AnoMesNum] / 100 ) * 12 + MOD ( [AnoMesNum], 100 ) <= _NumFim
				                        && NOT ISBLANK ( [Valor] )
				                ),
				                [Valor]
				            )
				)
				
				```

	annotation PBI_Id = 378bbcdfb0864d7dbcef798e4e3b6a7e

