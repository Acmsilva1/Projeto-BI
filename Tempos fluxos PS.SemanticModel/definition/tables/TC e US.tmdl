	column 'Diferença minutos TC_US Solic/chec' =
			
			VAR Laudo = 'TC e US'[DT_LAUDO]
			VAR Chec  = 'TC e US'[DT_CHECAGEM]
			VAR Solic = 'TC e US'[DT_LIBERACAO]
			VAR DataBase =
			    IF(
			        ISBLANK(Chec),
			        Solic,     -- se não tem checagem, usa solicitação
			        Chec       -- senão, usa checagem
			    )
			RETURN
			IF(
			    ISBLANK(Laudo) || ISBLANK(DataBase),
			    BLANK(),               -- se faltar uma das duas datas => BLANK
			    (Laudo - DataBase) * 1440
			)
		lineageTag: 29174fb4-43f4-49f6-8ba8-9858207554f4
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Diferença minutos TC_US imagemXlaudo' =
			
			('TC e US'[DT_LAUDO] - 'TC e US'[DT_EXAME]) * 24 * 60
		lineageTag: b8f15d21-09e3-4e28-b92f-0ea7cf58e0a5
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Diferença minutos TC_US Solic/checXimag' =
			
			VAR Exame = 'TC e US'[DT_EXAME]
			VAR Chec  = 'TC e US'[DT_CHECAGEM]
			VAR Solic = 'TC e US'[DT_LIBERACAO]
			VAR DataBase =
			    IF(
			        ISBLANK(Chec),
			        Solic,     -- se não tem checagem, usa solicitação
			        Chec       -- senão, usa checagem
			    )
			RETURN
			IF(
			    ISBLANK(Exame) || ISBLANK(DataBase),
			    BLANK(),               -- se faltar uma das duas datas => BLANK
			    (Exame - DataBase) * 1440
			)
		lineageTag: 60fd5ace-30c2-4084-a34e-4520ba8c8d43
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Diferença minutos TC_US solicXimagem' =
			
			('TC e US'[DT_EXAME] - 'TC e US'[DT_LIBERACAO]) * 24 * 60
		lineageTag: 1a2caec0-cd8a-4190-9056-c70211e41162
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

