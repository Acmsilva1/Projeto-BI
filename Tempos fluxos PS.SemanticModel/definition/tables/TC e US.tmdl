table 'TC e US'
	lineageTag: f2cbbb9c-32d7-4bd9-a977-73a4687ec91d

	measure 'Qtd Atend > Meta Selecionada' =
			
			VAR Limite = [Valor Meta_TC_US]
			VAR Escolha = VALUE( SELECTEDVALUE( 'Parametro meta exames imagem'[Value2] ) )   -- força para número
			RETURN
			CALCULATE(
			    COUNT( 'TC e US'[NR_PRESCRICAO] ),
			    FILTER(
			        'TC e US',
			        SWITCH(
			            Escolha,
			            0, 'TC e US'[Diferença minutos TC_US Solic/chec],
			            1, 'TC e US'[diferença minutos tc_us]
			        ) > Limite
			    )
			)
		formatString: 0
		lineageTag: 49a5ca3e-1e13-4c57-bc1f-7d8e488d01c4

	measure 'Qtd Atend > Meta solicXimagem' =
			
			VAR Limite = [Valor Meta TC_US_imagem]
			VAR Escolha = VALUE( SELECTEDVALUE( 'Parametro meta exames imagem'[Value2] ) )   -- força para número
			RETURN
			CALCULATE(
			    COUNT( 'TC e US'[NR_PRESCRICAO] ),
			    FILTER(
			        'TC e US',
			        SWITCH(
			            Escolha,
			            0, 'TC e US'[Diferença minutos TC_US Solic/checXimag],
			            1, 'TC e US'[Diferença minutos TC_US solicXimagem]
			        ) > Limite
			    )
			)
		formatString: 0
		lineageTag: 9ade5ea5-faf0-4241-b35a-72be710eb44e

