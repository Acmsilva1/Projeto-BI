	column DATA_DESFECHO =
			
			DATE ( YEAR ( fluxo[DT_DESFECHO] ), MONTH ( fluxo[DT_DESFECHO] ), DAY ( fluxo[DT_DESFECHO] ) )
		formatString: Short Date
