		annotation SummarizationSetBy = Automatic

	column Readmissao_CID_Igual =
			
			IF (
			    fluxo[Readmissao_Em_Ate_1_Dia] = 1,
			    VAR cidAnterior =
			        CALCULATE (
			            MAX (fluxo[CD_CID]),
			            FILTER (
			                fluxo,
			                fluxo[CD_PESSOA_FISICA] = EARLIER (fluxo[CD_PESSOA_FISICA]) &&
			                fluxo[DT_ENTRADA] = EARLIER (fluxo[Data_Anterior])
			            )
			        )
			    RETURN
			        IF (
			            fluxo[CD_CID] = cidAnterior,
			            "Mesmo CID",
			            "CID diferente"
			        ),
			    BLANK()
			)
		lineageTag: 3d4cf125-a55a-4bb9-ba43-d9674d498653
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

