	column Faixa_Etaria =
			
			SWITCH(
			    TRUE(),
			    VALUE(fluxo[IDADE]) < 0, "Idade inválida",
			    VALUE(fluxo[IDADE]) <= 19, "0-19",
			    VALUE(fluxo[IDADE]) <= 39, "20-39",
			    VALUE(fluxo[IDADE]) <= 59, "40-59",
			    VALUE(fluxo[IDADE]) <= 79, "60-79",
			    VALUE(fluxo[IDADE]) <= 99, "80-99",
			    VALUE(fluxo[IDADE]) <= 119, "100-119",
			    VALUE(fluxo[IDADE]) >= 120, "120+"
			)
		lineageTag: ff938ffe-e23b-4a99-9bf4-9c8c7007bd57
		summarizeBy: none
		sortByColumn: Faixa_Etaria_Ordem

		changedProperty = SortByColumn

		annotation SummarizationSetBy = Automatic

	column Faixa_Etaria_Ordem =
			
			SWITCH(
			    TRUE(),
			    VALUE(fluxo[IDADE]) >= 0 && VALUE(fluxo[IDADE]) <= 19, 1,
			    VALUE(fluxo[IDADE]) >= 20 && VALUE(fluxo[IDADE]) <= 39, 2,
			    VALUE(fluxo[IDADE]) >= 40 && VALUE(fluxo[IDADE]) <= 59, 3,
			    VALUE(fluxo[IDADE]) >= 60 && VALUE(fluxo[IDADE]) <= 79, 4,
			    VALUE(fluxo[IDADE]) >= 80 && VALUE(fluxo[IDADE]) <= 99, 5,
			    VALUE(fluxo[IDADE]) >= 100 && VALUE(fluxo[IDADE]) <= 119, 6,
			    VALUE(fluxo[IDADE]) >= 120, 7,
			    0
			)
		formatString: 0
		lineageTag: a971f1be-1714-4ff0-b173-9db4709e41ab
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column CD_PESSOA_FISICA
		dataType: string
		lineageTag: 45f03872-8fba-48ef-8b8f-f88df3668b31
		summarizeBy: none
		sourceColumn: CD_PESSOA_FISICA

		annotation SummarizationSetBy = Automatic

	column DT_ALTA_MEDICO
		dataType: dateTime
		formatString: General Date
		lineageTag: 5cd07e49-d6e3-4a99-9d86-d4fe4a0e5c9e
		summarizeBy: none
		sourceColumn: DT_ALTA_MEDICO

		variation Variation
			isDefault
			relationship: a43630dc-d785-43ab-afdd-d71fcbbc9173
			defaultHierarchy: LocalDateTable_3dbd6ec8-185b-4569-9007-ff615f2711d8.'Hierarquia de datas'

		annotation SummarizationSetBy = Automatic

	column Data_Anterior =
			
			CALCULATE(
			    MAX(fluxo[DT_ENTRADA]),
			    FILTER(
			        fluxo,
			        fluxo[CD_PESSOA_FISICA] = EARLIER(fluxo[CD_PESSOA_FISICA]) &&
			        fluxo[DT_ENTRADA] < EARLIER(fluxo[DT_ENTRADA])
			    )
			)
		formatString: General Date
		lineageTag: 687e6d98-89e2-4f37-9667-a5556b384787
		summarizeBy: none

		variation Variation
			isDefault
			relationship: a2d28463-53f1-4e6f-b434-df76c631cdc5
			defaultHierarchy: LocalDateTable_e1e1fe90-7ed1-4aa0-a064-d3ea2e648e64.'Hierarquia de datas'

		annotation SummarizationSetBy = Automatic

	column Dias_Entre_Atendimentos =
			
			DATEDIFF(
			    fluxo[Data_Anterior],
			    fluxo[DT_ENTRADA],
			    DAY
			)
		formatString: 0
		lineageTag: 4063559b-b34d-47f6-b5a9-870f9db62008
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column Readmissao_Em_Ate_1_Dia =
			
			IF(
			    NOT ISBLANK(fluxo[Data_Anterior]) &&
			    fluxo[Dias_Entre_Atendimentos] <= 1,
			    1,
			    0
			)
		formatString: 0
		lineageTag: 75330265-c491-412e-8d66-a65be86fb2ef
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

