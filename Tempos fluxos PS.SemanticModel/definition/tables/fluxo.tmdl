	partition fluxo = m
		mode: import
		source = ```
				let
				    Fonte = PostgreSQL.Database("10.250.50.151:6433", "db"),
				    cmc_hospital_tbl_tempos_entrada_consulta_saida = Fonte{[Schema="cmc_hospital",Item="tbl_tempos_entrada_consulta_saida"]}[Data],
				    #"Tipo Alterado" = Table.TransformColumnTypes(#"cmc_hospital_tbl_tempos_entrada_consulta_saida",{{"UNIDADE", type text}, {"NR_ATENDIMENTO", Int64.Type}, {"PACIENTE", type text}, {"DT_ENTRADA", type datetime}, {"DT_TRIAGEM", type datetime}, {"DT_FIM_TRIAGEM", type datetime}, {"DT_ATEND_MEDICO", type datetime}, {"DT_ALTA", type datetime}, {"MIN_ENTRADA_X_TRIAGEM", type number}, {"MIN_ENTRADA_X_CONSULTA", type number}, {"MIN_ENTRADA_X_ALTA", type number}}),
				    #"Coluna Duplicada" = Table.DuplicateColumn(#"Tipo Alterado", "DT_ENTRADA", "DT_ENTRADA - Copiar"),
				    #"Tipo Alterado1" = Table.TransformColumnTypes(#"Coluna Duplicada",{{"DT_ENTRADA - Copiar", type date}}),
				    #"Colunas Reordenadas" = Table.ReorderColumns(#"Tipo Alterado1",{"UNIDADE", "NR_ATENDIMENTO", "PACIENTE", "DT_ENTRADA - Copiar", "DT_ENTRADA", "DT_TRIAGEM", "DT_FIM_TRIAGEM", "DT_ATEND_MEDICO", "DT_ALTA", "MIN_ENTRADA_X_TRIAGEM", "MIN_ENTRADA_X_CONSULTA", "MIN_ENTRADA_X_ALTA"}),
				    #"Valor Substituído" = Table.ReplaceValue(#"Colunas Reordenadas","Medsenior ","",Replacer.ReplaceText,{"UNIDADE"}),
