table medicacao
	lineageTag: 265cd6fa-a81d-494b-85e6-508795429b1e

	measure Icone_Atendimentos =
			
			VAR DataRef = MAXX ( ALL ( fluxo ), fluxo[DATA] ) - 1
			VAR Dias    = SELECTEDVALUE ( Qtde_dias[Qtde_dias], 30 )
			VAR DataIni = DataRef - Dias
			
			-- contexto atual (linha/coluna da matriz)
			VAR CtxMin  = MIN ( 'Calendario'[Data] )
			VAR CtxMax  = MAX ( 'Calendario'[Data] )
			
			-- interseção janela x contexto
			VAR EffIni  = MAX ( DataIni, CtxMin )
			VAR EffFim  = MIN ( DataRef, CtxMax )
			
			VAR Limite  = SELECTEDVALUE ( Qtde_atd[Qtde_atd], 0 )
			
			-- atendimentos apenas na interseção de datas
			VAR Valor   =
			    CALCULATE (
			        COUNTROWS ( fluxo ),                       -- troque por SUM(fluxo[Qtd]) se existir
			        KEEPFILTERS ( fluxo[DATA] >= EffIni ),
			        KEEPFILTERS ( fluxo[DATA] <= EffFim )
			    )
			RETURN
			IF (
			    Limite <= 0 || EffIni > EffFim,               -- sem limite ou sem sobreposição
			    BLANK (),
			    IF ( Valor >= Limite, 1, 0 )
			)
		formatString: 0
		lineageTag: 560b174b-8d22-4eea-ad70-cc84e50c4517

