	column 'Diferença Minutos presc_realizacao' =
			
			VAR Exame = medicacao[DT_ADMINISTRACAO]
			VAR Solic = medicacao[DT_PRESCRICAO]
			RETURN
			IF(
			    ISBLANK(Exame) || ISBLANK(Solic),
			    BLANK(),                          // sem uma das datas => nulo
			    INT( (Exame - Solic) * 1440 )     // minutos (1440 = 24*60); INT para inteiro
			)
		formatString: 0
		lineageTag: cc861c46-b9c6-480d-9b68-c9555b016578
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

