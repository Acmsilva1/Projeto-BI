	partition reavaliacao = m
		mode: import
		source = ```
				let
				    Fonte = PostgreSQL.Database("10.250.50.151:6433", "db"),
				    cmc_hospital_tbl_tempos_reavaliacao = 
				        Fonte{[Schema="cmc_hospital", Item="tbl_tempos_reavaliacao"]}[Data],
				
				    #"Tipo Alterado" = 
				        Table.TransformColumnTypes(
				            cmc_hospital_tbl_tempos_reavaliacao,
				            {
				                {"UNIDADE", type text},
				                {"NR_ATENDIMENTO", Int64.Type},
				                {"PACIENTE", type text},
				                {"DT_SOLIC_REAVALIACAO", type datetime},
				                {"DT_FIM_REAVALIACAO", type datetime},
				                {"MINUTOS", type number},
				                {"HORAS", type number},
				                {"DATA", type date},
				                {"PESSOA_REAVALIACAO", type text}
				            }
				        ),
				
				    #"Remove Nulos Pessoa Reavaliacao" =
				        Table.SelectRows(
				            #"Tipo Alterado",
				            each [PESSOA_REAVALIACAO] <> null
				        )
				in
				    #"Remove Nulos Pessoa Reavaliacao"
				```

	annotation PBI_ResultType = Table

