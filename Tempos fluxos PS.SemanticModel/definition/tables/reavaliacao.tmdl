	column Min_evolu_reav =
			
			VAR DtIni = reavaliacao[DT_SOLIC_REAVALIACAO]
			VAR DtEvo = reavaliacao[DT_EVO_PRESC]
			VAR DtFim = reavaliacao[DT_FIM_REAVALIACAO]
			VAR DtRef =
			    SWITCH (
			        TRUE (),
			        ISBLANK ( DtEvo ) && ISBLANK ( DtFim ), BLANK (),
			        ISBLANK ( DtEvo ), DtFim,
			        ISBLANK ( DtFim ), DtEvo,
			        DtEvo <= DtFim, DtEvo,
			        DtFim
			    )
			RETURN
			IF (
			    ISBLANK ( DtIni ) || ISBLANK ( DtRef ),
			    BLANK (),
			    DATEDIFF ( DtIni, DtRef, MINUTE )
			)
		formatString: 0
		lineageTag: 4be8c730-3fbc-4d81-a7f9-923610d52341
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isDecimal":true}

