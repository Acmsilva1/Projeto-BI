# Copie para um ficheiro à sua escolha (ex.: docker.env) e use:
#   docker compose --env-file docker.env up --build
# (Não use prefixo .env.* se o .gitignore bloquear commits de exemplos.)

BACKEND_PUBLISH_PORT=3020
FRONTEND_PUBLISH_PORT=8080
REDIS_PUBLISH_PORT=6379

BIND_HOST=0.0.0.0
HOSPITAL_BI_API_PORT=3020

REDIS_URL=redis://redis:6379
REDIS_OFFLINE_USE_MEMORY=1
CACHE_FORCE_MEMORY=0
REDIS_CONNECT_TIMEOUT_MS=4000

DB_FALLBACK_READ_STALE=1
DB_FALLBACK_WRITE_STALE=1
DB_FALLBACK_STALE_TTL_SEC=86400

DATA_SOURCE=csv
CSV_DATOS_DIR=/data/dados

CORS_EXTRA_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
FRONTEND_URL=http://localhost:8080

VITE_API_BASE=/api
