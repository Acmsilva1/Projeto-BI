PORT=3001

# Credenciais Supabase (modo live)
SUPABASE_URL=
SUPABASE_KEY=

# Desabilita scheduler de predição em dev local
DISABLE_PREDICTOR_SCHEDULER=true

# ── Cache Redis ─────────────────────────────────────────────
# true = habilita cache  |  false = app roda sem cache (seguro)
CACHE_ENABLED=true
CACHE_REDIS_URL=redis://localhost:6379

# ── Mensageria RabbitMQ ──────────────────────────────────────
# true = habilita fila   |  false = app roda sem mensageria (seguro)
QUEUE_ENABLED=true
QUEUE_RABBIT_URL=amqp://guest:guest@localhost:5672
