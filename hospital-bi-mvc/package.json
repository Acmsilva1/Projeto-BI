{
  "name": "hospital_bi_mvc",
  "version": "2.0.0",
  "description": "Hospital BI - 100% Node.js MVC & Tailwind",
  "main": "api/server.js",
  "scripts": {
    "dev": "concurrently \"npm run api\" \"npm run css:watch\" \"npm run frontend\"",
    "api": "node api/server.js",
    "css:watch": ".\\node_modules\\.bin\\tailwindcss -i ./css/input.css -o ./css/style.css --watch",
    "css:build": ".\\node_modules\\.bin\\tailwindcss -i ./css/input.css -o ./css/style.css --minify",
    "frontend": "vite --host 127.0.0.1 --port 5173",
    "clean": "rimraf backend scripts",
    "pipeline:once": "python pipeline_guard.py --once",
    "pipeline:watch": "python pipeline_guard.py --interval 3"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "concurrently": "^8.2.2",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^4.22.1",
    "pg": "^8.20.0"
  }
}
