{
  "watch_roots": [
    "api",
    "js",
    "css",
    "index.html",
    "package.json",
    "vite.config.js",
    "tailwind.config.js"
  ],
  "ignore_globs": [
    ".git/*",
    "node_modules/*",
    "dist/*",
    ".codex-logs/*",
    "pipeline_guard_logs/*",
    "api/__pycache__/*",
    "api/routers/__pycache__/*",
    "api/models/__pycache__/*",
    "api/schemas/__pycache__/*",
    "api/database/__pycache__/*"
  ],
  "scan_files_for_encoding": [
    "api/server.js",
    "api/live_service.js",
    "api/db.js",
    "js/app.js",
    "index.html"
  ],
  "encoding_bad_patterns": [
    "횄징",
    "횄짖",
    "횄짙",
    "횄짠",
    "횄짤",
    "횄짧",
    "횄짯",
    "횄쨀",
    "횄쨈",
    "횄쨉",
    "횄쨘",
    "횄 ",
    "횂",
    "챦쩔쩍"
  ],
  "commands": [
    {
      "name": "backend_syntax_server",
      "cmd": ["node", "--check", "api/server.js"],
      "cwd": "."
    },
    {
      "name": "backend_syntax_live_service",
      "cmd": ["node", "--check", "api/live_service.js"],
      "cwd": "."
    },
    {
      "name": "backend_syntax_db",
      "cmd": ["node", "--check", "api/db.js"],
      "cwd": "."
    },
    {
      "name": "frontend_build",
      "cmd": ["npm", "run", "css:build"],
      "cwd": ".",
      "timeout_sec": 120
    }
  ]
}
