	column 'Óbito > 24h' =
			
			IF(
			    NOT ISBLANK( Internacao[DT_ENTRADA] ) &&
			    NOT ISBLANK( Internacao[DT_ALTA] ) &&
			    Internacao[MOTIVO_ALTA_HOSPITALAR] = "Óbito" &&
			    DATEDIFF(
			        Internacao[DT_ENTRADA],
			        Internacao[DT_ALTA],
			        HOUR
			    ) >= 24,
			    "SIM",
			    BLANK()
			)
		lineageTag: 37042509-e3a6-4e1a-bdfa-6cfc812fa348
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

