		annotation SummarizationSetBy = Automatic

	column DT_ALTA_MEDICA_CONDIC = ```
			-- para trazer a data da alta hospitalar, quando a data da alta médica for maior que a data da alta hospitalar
			VAR AltaMedico = 'Internacao'[DT_ALTA_MEDICO]
			VAR Alta       = 'Internacao'[DT_ALTA]
			RETURN
			IF(
			    ISBLANK(AltaMedico),
			    BLANK(),
			    IF(
			        AltaMedico > Alta,
			        Alta,
			        AltaMedico
			    )
			)
			
			```
		formatString: General Date
		lineageTag: e3ab7911-3ebc-458c-80a5-55342ee9502a
		summarizeBy: none

		variation Variation
			isDefault
			relationship: 521e5286-0abe-4e38-9f7b-487b2397f385
			defaultHierarchy: LocalDateTable_5ccf10af-f288-4fc8-8560-d8d2afb960d1.'Hierarquia de datas'

		annotation SummarizationSetBy = Automatic

