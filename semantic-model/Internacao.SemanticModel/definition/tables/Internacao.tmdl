	column 'UF unidade' =
			
			VAR Texto = TRIM ( Internacao[UNIDADE] )
			RETURN
			IF (
			    LEN ( Texto ) >= 2,
			    LEFT ( Texto, 2 ),
			    BLANK ()
			)
		lineageTag: be353a44-fe2f-4969-81ec-49931997df8c
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Data alta anterior' =
			
			VAR PacienteAtual = Internacao[CD_PESSOA_FISICA]
			VAR DtEntradaAtual = Internacao[DT_ENTRADA]
			RETURN
			CALCULATE (
			    MAX ( Internacao[DT_ALTA] ),
			    FILTER (
			        Internacao,
			        Internacao[CD_PESSOA_FISICA] = PacienteAtual
			            && Internacao[DT_ALTA] < DtEntradaAtual
			            && NOT ISBLANK ( Internacao[DT_ALTA] )
			    )
			)
		formatString: General Date
		lineageTag: dc39489f-d9b7-4ed9-9293-2b476f891974
		summarizeBy: none

		variation Variation
			isDefault
			relationship: ea5bfd35-9802-4bc8-9976-4036ae86d749
			defaultHierarchy: LocalDateTable_bc6269c6-27d8-49d5-86da-bddf3b84e212.'Hierarquia de datas'

		annotation SummarizationSetBy = Automatic

	column 'Dias desde alta anterior' = ```
			
			VAR DtAltaAnterior = Internacao[Data alta anterior]
			VAR DtEntradaAtual = Internacao[DT_ENTRADA]
			RETURN
			IF (
			    ISBLANK ( DtAltaAnterior ),
			    BLANK(),
			    DATEDIFF ( DtAltaAnterior, DtEntradaAtual, DAY )
			)
			
			```
		formatString: 0
		lineageTag: a2cddbc1-1b97-4257-817c-891c52ea2cac
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column DT_ALTA_DATA
		dataType: dateTime
		formatString: Short Date
		lineageTag: 6307f0b0-1ce6-425b-95d9-ccebca037ebe
		summarizeBy: none
		sourceColumn: DT_ALTA_DATA

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	column Faixa_Etaria =
			
			SWITCH(
			    TRUE(),
			    VALUE(Internacao[IDADE]) < 0, "Idade inválida",
			    VALUE(Internacao[IDADE]) <= 19, "0-19",
			    VALUE(Internacao[IDADE]) <= 39, "20-39",
			    VALUE(Internacao[IDADE]) <= 59, "40-59",
			    VALUE(Internacao[IDADE]) <= 79, "60-79",
			    VALUE(Internacao[IDADE]) <= 99, "80-99",
			    VALUE(Internacao[IDADE]) <= 119, "100-119",
			    VALUE(Internacao[IDADE]) >= 120, "120+"
			)
		lineageTag: 8e2f245f-209d-4dd1-84dc-e13b16c56224
		summarizeBy: none
		sortByColumn: Faixa_Etaria_Ordem

		changedProperty = SortByColumn

		annotation SummarizationSetBy = Automatic

	column Faixa_Etaria_Ordem =
			
			SWITCH(
			    TRUE(),
			    VALUE(Internacao[IDADE]) >= 0 && VALUE(Internacao[IDADE]) <= 19, 1,
			    VALUE(Internacao[IDADE]) >= 20 && VALUE(Internacao[IDADE]) <= 39, 2,
			    VALUE(Internacao[IDADE]) >= 40 && VALUE(Internacao[IDADE]) <= 59, 3,
			    VALUE(Internacao[IDADE]) >= 60 && VALUE(Internacao[IDADE]) <= 79, 4,
			    VALUE(Internacao[IDADE]) >= 80 && VALUE(Internacao[IDADE]) <= 99, 5,
			    VALUE(Internacao[IDADE]) >= 100 && VALUE(Internacao[IDADE]) <= 119, 6,
			    VALUE(Internacao[IDADE]) >= 120, 7,
			    0
			)
		formatString: 0
		lineageTag: 67ac6185-85d1-44ad-95e2-ef47b55ba0cf
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Difer minutos alta medicaXhosp' = ```
			
			IF(
			    ISBLANK(Internacao[DT_ALTA_MEDICA_CONDIC]),
			    BLANK(),   
			    (Internacao[DT_ALTA] - Internacao[DT_ALTA_MEDICA_CONDIC]) * 24 * 60
			)
			```
		lineageTag: 864976f4-31a2-41fe-a963-69f2c37a47bd
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Reinternacao 7d mesmo CID' = ```
			
			VAR Paciente   = Internacao[CD_PESSOA_FISICA]
			VAR CIDAtual   = Internacao[CID]          -- ou Internacao[CD_CID], se preferir
			VAR DataAlta   = Internacao[DT_ALTA]
			RETURN
			IF(
			    NOT ISBLANK( DataAlta ),
			    VAR ProxInternacao =
			        CALCULATE(
			            MIN( Internacao[DT_ENTRADA] ),   -- data da próxima internação
			            FILTER(
			                ALL( Internacao ),
			                Internacao[CD_PESSOA_FISICA] = Paciente &&
			                Internacao[CID]              = CIDAtual &&
			                Internacao[DT_ENTRADA]       >  DataAlta &&
			                Internacao[DT_ENTRADA]       <= DataAlta + 7
			            )
			        )
			    RETURN IF( NOT ISBLANK( ProxInternacao ), 1, 0 ),
			    BLANK()
			)
			
			```
		formatString: 0
		lineageTag: d30b3528-94cd-4c29-b029-c70721c34936
		summarizeBy: count

		annotation SummarizationSetBy = Automatic

	column 'Reinternacao 30d mesmo CID' = ```
			
			VAR Paciente = Internacao[CD_PESSOA_FISICA]
			VAR CIDAtual = Internacao[CID]              -- ou Internacao[CD_CID], se preferir
			VAR DataAlta = Internacao[DT_ALTA]
			RETURN
			IF(
			    NOT ISBLANK( DataAlta ),
			    VAR ProxInternacao =
			        CALCULATE(
			            MIN( Internacao[DT_ENTRADA] ),  -- data da próxima internação
			            FILTER(
			                ALL( Internacao ),
			                Internacao[CD_PESSOA_FISICA] = Paciente &&
			                Internacao[CID]              = CIDAtual &&   -- mesmo CID
			                Internacao[DT_ENTRADA]       >  DataAlta &&
			                Internacao[DT_ENTRADA]       <= DataAlta + 30
			            )
			        )
			    RETURN IF( NOT ISBLANK( ProxInternacao ), 1, 0 ),
			    BLANK()
			)
			
			```
		formatString: 0
		lineageTag: bede2161-62ee-46a0-b994-1f9e2f57d3b3
		summarizeBy: count

		annotation SummarizationSetBy = Automatic

