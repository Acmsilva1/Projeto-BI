	measure 'Qtd altas hosp até 2h (dt entrada)' =
			-- para as páginas com slicer com dt_entrada
			VAR DatasSelecionadas =
			    VALUES ( Calendario[Data] )
			
			VAR BaseSemFiltroEntrada =
			    CALCULATETABLE(
			        Internacao,
			        REMOVEFILTERS ( Calendario ),
			        REMOVEFILTERS (
			            Internacao[DATA],
			            Internacao[DT_ENTRADA],
			            Internacao[DATA]
			        )
			    )
			
			RETURN
			COUNTROWS (
			    SUMMARIZE (
			        FILTER (
			            BaseSemFiltroEntrada,
			            NOT ISBLANK ( Internacao[DT_ALTA_MEDICA_CONDIC] ) &&
			            NOT ISBLANK ( Internacao[DT_ALTA] ) &&
			            Internacao[DT_ALTA] <= Internacao[DT_ALTA_MEDICA_CONDIC] + TIME ( 2, 0, 0 ) &&
			            Internacao[DT_ALTA_DATA] IN DatasSelecionadas
			        ),
			        Internacao[NR_ATENDIMENTO]
			    )
			)
		formatString: 0
		displayFolder: Altas
		lineageTag: ff0b3251-b022-4ef0-bcfe-05595eccc177

	measure '% altas hosp até 2h' = ```
			
			DIVIDE(
