			            REMOVEFILTERS ( Internacao ),
			            TREATAS ( UnidadesSelecionadas, UTI_Episodios[UNIDADE] )
			        ),
			        NOT ISBLANK ( UTI_Episodios[DT_SAIDA_UTI] ) &&
			        INT ( UTI_Episodios[DT_SAIDA_UTI] ) IN DatasSelecionadas
