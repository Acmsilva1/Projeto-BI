	measure 'Pacientes UTI censo 0h' =
			
			VAR d =
			    SELECTEDVALUE ( Calendario[Data] )
			
			VAR UnidadesSelecionadas =
			    CALCULATETABLE(
			        VALUES ( Internacao[UNIDADE] ),
			        REMOVEFILTERS ( Calendario )
			    )
			
			VAR BaseEpisodios =
			    CALCULATETABLE(
			        UTI_Episodios,
			        REMOVEFILTERS ( Calendario ),
			        REMOVEFILTERS ( Internacao ),
			        TREATAS ( UnidadesSelecionadas, UTI_Episodios[UNIDADE] )
			    )
			
			RETURN
			IF (
			    ISBLANK ( d ),
			    BLANK(),
			    COUNTROWS (
			        FILTER (
			            BaseEpisodios,
			            UTI_Episodios[DT_ENTRADA_UTI] < d &&
			            (
			                ISBLANK ( UTI_Episodios[DT_SAIDA_UTI] ) ||
			                UTI_Episodios[DT_SAIDA_UTI] >= d
			            )
			        )
