	measure 'Qtd altas hosp com alta médica' =
			
			CALCULATE(
			    DISTINCTCOUNT(Internacao[NR_ATENDIMENTO]),
			    NOT ISBLANK(Internacao[DT_ALTA_MEDICO]),
