		displayFolder: Altas
		lineageTag: 9e484e0c-0a28-4c1e-bc78-43c3327f1544

	measure 'Ranking % reinternacoes 7d UF' = ```
			
			VAR TabelaUFBase =
			    ADDCOLUMNS(
			        ALLSELECTED( Internacao[UF unidade] ),        
			        "QtdAltas", CALCULATE( [Qtd de altas] ),
			        "Taxa",     CALCULATE( [% reinternacao 7d] )
			    )
			-- considera só UFs que tiveram pelo menos 1 alta no período
			VAR TabelaUF =
			    FILTER(
			        TabelaUFBase,
			        [QtdAltas] > 0
			    )
			VAR MaxTaxa = MAXX( TabelaUF, [Taxa] )
			VAR MinTaxa = MINX( TabelaUF, [Taxa] )
			VAR TaxaAtual  = [% reinternacao 7d]
			VAR AltasAtual = [Qtd de altas]
			RETURN
			IF (
			    AltasAtual > 0,   -- só mostra ícone se essa UF teve alta no período
			    SWITCH(
			        TRUE(),
			        MaxTaxa = MinTaxa, BLANK(),          -- todo mundo igual → não destaca ninguém
			        TaxaAtual = MaxTaxa, UNICHAR(9650),  -- ▲ maior taxa (pior)
			        TaxaAtual = MinTaxa, UNICHAR(9660),  -- ▼ menor taxa (melhor)
			        BLANK()
			    ),
			    BLANK()
			)
			
			```
		displayFolder: Reinternação
		lineageTag: 97654a3d-7e2c-4593-a228-a800ebba2db4

	measure 'Ranking TMP (dias) UF' = ```
			
			VAR TabelaUFBase =
			    ADDCOLUMNS(
			        ALLSELECTED( Internacao[UF unidade] ),
			        "Altas", CALCULATE( [Qtd de altas] ),
			        "TMP",   CALCULATE( [TMP (dias)] )
			    )
			-- só UFs que tiveram alta no período
			VAR TabelaUF =
			    FILTER(
			        TabelaUFBase,
			        [Altas] > 0
			            && NOT ISBLANK( [TMP] )
			    )
			VAR MaxTMP   = MAXX( TabelaUF, [TMP] )
			VAR MinTMP   = MINX( TabelaUF, [TMP] )
			VAR TMPAtual = [TMP (dias)]
			VAR AltasAtual = [Qtd de altas]
			RETURN
			IF(
			    AltasAtual > 0           -- só mostra ícone se essa UF teve alta
			        && MaxTMP > MinTMP,  -- evita setas se todo mundo tiver o mesmo TMP
			    SWITCH(
			        TRUE(),
			        TMPAtual = MaxTMP, UNICHAR(9650),  -- ▲ maior TMP (pior desempenho)
			        TMPAtual = MinTMP, UNICHAR(9660),  -- ▼ menor TMP (melhor desempenho)
			        BLANK()
			    ),
			    BLANK()
			)
			
			```
		displayFolder: Outros
		lineageTag: b44a655c-ebe1-4e21-a39e-d3f423791ce5

