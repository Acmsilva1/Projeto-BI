	measure 'Ranking internações UF' =
			
			VAR TabelaUF =
			    ADDCOLUMNS(
			        ALLSELECTED( Internacao[UF unidade] ),   -- todas as UFs visíveis no contexto (mês, filtros, etc.)
			        "Qtd", CALCULATE( [Qtd internacoes] )    -- quantidade de internações por UF dentro do contexto atual
			    )
			VAR MaxQtd = MAXX( TabelaUF, [Qtd] )
			VAR MinQtd = MINX( TabelaUF, [Qtd] )
			VAR QtdAtual = [Qtd internacoes]
			RETURN
			SWITCH(
			    TRUE(),
			    -- Se todas as UFs têm o mesmo valor, não destaca ninguém
			    MaxQtd = MinQtd, BLANK(),
			
			    -- Maior valor entre as UFs visíveis -> seta pra cima
			    QtdAtual = MaxQtd, UNICHAR(9650),   -- ▲
			
			    -- Menor valor entre as UFs visíveis -> seta pra baixo
			    QtdAtual = MinQtd, UNICHAR(9660),   -- ▼
			
			    -- Demais UFs, sem ícone
			    BLANK()
			)
		displayFolder: Internação
		lineageTag: 8f98e8d4-e7df-490c-8003-e70997746504

	measure 'Ranking altas UF' =
			
			VAR TabelaUF =
			    ADDCOLUMNS(
			        ALLSELECTED( Internacao[UF unidade] ),   -- todas as UFs visíveis no contexto (mês, filtros, etc.)
			        "Qtd", CALCULATE( [Qtd de altas] )    -- quantidade de altas por UF dentro do contexto atual
			    )
			VAR MaxQtd = MAXX( TabelaUF, [Qtd] )
			VAR MinQtd = MINX( TabelaUF, [Qtd] )
			VAR QtdAtual = [Qtd de altas]
			RETURN
			SWITCH(
			    TRUE(),
			    -- Se todas as UFs têm o mesmo valor, não destaca ninguém
			    MaxQtd = MinQtd, BLANK(),
			
			    -- Maior valor entre as UFs visíveis -> seta pra cima
			    QtdAtual = MaxQtd, UNICHAR(9650),   -- ▲
			
			    -- Menor valor entre as UFs visíveis -> seta pra baixo
			    QtdAtual = MinQtd, UNICHAR(9660),   -- ▼
			
