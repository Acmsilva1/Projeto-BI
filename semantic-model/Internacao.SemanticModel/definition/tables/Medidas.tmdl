	measure 'Paciente internado no período' =
			
			VAR DataIni = MIN(Calendario[Data])
			VAR DataFim = MAX(Calendario[Data])
			VAR Entrada = INT(SELECTEDVALUE(Internacao[DT_ENTRADA]))
			VAR Alta =
			    IF(
			        ISBLANK(SELECTEDVALUE(Internacao[DT_ALTA])),
			        DataFim,
			        INT(SELECTEDVALUE(Internacao[DT_ALTA]))
			    )
			RETURN
			IF(
			    NOT ISBLANK(Entrada) &&
			    Entrada <= DataFim &&
			    Alta >= DataIni,
			    1,
			    0
			)
		formatString: 0
		displayFolder: Internação
		lineageTag: 55488177-d486-45ad-9cea-941f6acf3bc4

	measure 'Pacientes internados no dia' =
			
			VAR DataRef =
			    SELECTEDVALUE ( Calendario[Data] )
			
			VAR BaseSemFiltroData =
			    CALCULATETABLE (
			        Movimentacao_pac,
			        REMOVEFILTERS ( Calendario ),
			        REMOVEFILTERS (
			            Movimentacao_pac[DATA],
			            Movimentacao_pac[DT_HISTORICO],
			            Movimentacao_pac[DT_FIM_HISTORICO]
			        )
			    )
			
			RETURN
			IF (
			    ISBLANK ( DataRef ),
			    BLANK(),
			    COUNTROWS (
			        SUMMARIZE (
			            FILTER (
			                BaseSemFiltroData,
			                NOT ISBLANK ( Movimentacao_pac[NR_ATENDIMENTO] ) &&
			                NOT ISBLANK ( Movimentacao_pac[DT_HISTORICO] ) &&
			                Movimentacao_pac[DT_HISTORICO] < DataRef &&
			                COALESCE ( Movimentacao_pac[DT_FIM_HISTORICO], NOW() ) >= DataRef
			            ),
			            Movimentacao_pac[NR_ATENDIMENTO]
			        )
			    )
			)
		formatString: 0
		displayFolder: Internação
		lineageTag: ae4b9a9d-87a8-4a33-8d2d-a8cbc278361f

	measure 'Paciente entra TMP' =
			
			VAR DataIni =
			    MIN ( Calendario_TMP[Date] )
			VAR DataFim =
			    MAX ( Calendario_TMP[Date] )
			VAR AtendimentoAtual =
			    SELECTEDVALUE ( Internacao[NR_ATENDIMENTO] )
			
			VAR BaseSemFiltroEntrada =
			    CALCULATETABLE(
			        Internacao,
			        REMOVEFILTERS ( Calendario ),
			        REMOVEFILTERS (
			            Internacao[DATA],
			            Internacao[DT_ENTRADA]
			        )
			    )
			
			VAR TemTMP =
			    COUNTROWS (
			        FILTER (
			            BaseSemFiltroEntrada,
			            Internacao[NR_ATENDIMENTO] = AtendimentoAtual &&
			            NOT ISBLANK ( Internacao[DT_ENTRADA] ) &&
			            Internacao[DT_ENTRADA] < DataFim &&
			            (
			                ISBLANK ( Internacao[DT_ALTA] ) ||
			                Internacao[DT_ALTA] >= DataIni
			            )
			        )
			    )
			
			RETURN
			IF (
			    NOT ISBLANK ( AtendimentoAtual ) &&
			    NOT ISBLANK ( DataIni ) &&
			    NOT ISBLANK ( DataFim ) &&
			    TemTMP > 0,
			    1,
			    0
			)
		formatString: 0
		displayFolder: Outros
		lineageTag: cc662a6c-7101-4af8-8a2b-3cb9aa7cc20b

	measure 'Dias permanência TMP' =
			
			VAR Entrada = MAX(Internacao[DT_ENTRADA])
			VAR Alta    = MAX(Internacao[DT_ALTA])
			VAR DataEntrada = INT(Entrada)
			VAR DataAlta    = INT(Alta)
			RETURN
			IF(
			    NOT ISBLANK(Entrada) &&
			    NOT ISBLANK(Alta),
			    DataAlta - DataEntrada,
			    BLANK()
			)
		formatString: 0
		displayFolder: Outros
		lineageTag: 2838bd94-ce5a-4cf3-8a64-1100a79226a7

	measure 'Cor TMP por atendimento' =
			
