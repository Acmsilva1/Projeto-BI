	measure 'Paciente UTI censo 0h (flag)' =
			
			VAR d =
			    SELECTEDVALUE ( Calendario_TMP[Date] )
			VAR AtendimentoAtual =
			    SELECTEDVALUE ( Movimentacao_pac[NR_ATENDIMENTO] )
			
			VAR BaseSemFiltroData =
			    CALCULATETABLE(
			        Movimentacao_pac,
			        REMOVEFILTERS ( Calendario ),
			        REMOVEFILTERS (
			            Movimentacao_pac[HR_HISTORICO],
			            Movimentacao_pac[HR_FIM_HISTORICO],
			            Movimentacao_pac[DT_FIM_HISTORICO]
			        )
			    )
			
			VAR TemNoDia =
			    COUNTROWS (
			        FILTER (
			            BaseSemFiltroData,
			            Movimentacao_pac[NR_ATENDIMENTO] = AtendimentoAtual &&
			            TRIM ( UPPER ( Movimentacao_pac[CLASSIFICACAO] ) ) IN { "UTI", "UPC", "UTI EXTRA" } &&
			            Movimentacao_pac[HR_HISTORICO] <= d &&
			            (
			                ISBLANK ( Movimentacao_pac[HR_FIM_HISTORICO] ) ||
			                Movimentacao_pac[HR_FIM_HISTORICO] > d
			            )
			        )
			    )
			
			RETURN
			IF (
			    NOT ISBLANK ( d ) &&
			    NOT ISBLANK ( AtendimentoAtual ) &&
			    TemNoDia > 0,
			    1,
			    0
			)
		formatString: 0
		displayFolder: UTI
		lineageTag: 45cf2bda-431c-4905-b6c9-c655e8157d4b

