table Medidas
	lineageTag: 71847c61-e914-4fbd-9849-8f29a04f2eec

	measure 'Dia D-1' = ```
			
			VAR MaxDataAll =
			    CALCULATE ( MAX ( Internacao[DATA] ), ALL (Internacao) )
			VAR DataAnteriorDisponivel =
			    CALCULATE (
			        MAX (Internacao[DATA]),
			        FILTER (ALL(Internacao), Internacao[DATA] < MaxDataAll )
			    )
			RETURN
			    IF (
			        MaxDataAll = TODAY (),
			        DataAnteriorDisponivel,   -- se a última data é hoje, traz o D-1 disponível
			        MaxDataAll                -- se a última data é ontem (ou antes), traz normalmente
			    )
			
			```
		formatString: Short Date
		displayFolder: Outros
		lineageTag: 8fc5773c-5df4-48da-9ec9-c6068c576a6e

