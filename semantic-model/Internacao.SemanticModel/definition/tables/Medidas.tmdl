	measure 'Qtd leitos ativos' = ```
			-- leitos ativos até o fim do dia
			VAR Dia = MAX ( Calendario[Data] )   -- Data (sem hora)
			VAR FimDia = Dia + 1                -- D+1 00:00:00
			RETURN
			CALCULATE (
			    DISTINCTCOUNT ( Leitos[LEITO] ),
			    REMOVEFILTERS ( Leitos[DT_CRIACAO] ),
			    FILTER (
			        Leitos,
			        Leitos[DT_CRIACAO] < FimDia
			            &&
			        (
			            Leitos[IE_SITUACAO] = "A"
			            || ISBLANK ( Leitos[DT_ATUALIZACAO] )
			            || Leitos[DT_ATUALIZACAO] >= FimDia
			        )
			    )
			)
			
			```
		formatString: 0
		displayFolder: Outros
		lineageTag: 20569ab1-5834-4d04-9336-eea485446f5a

	measure 'Qtd obitos > 24h' =
			-- institucionais, somente por data de alta
			VAR DatasSelecionadas =
			    VALUES ( Calendario[Data] )
			
			VAR BaseSemFiltroEntrada =
			    CALCULATETABLE(
			        Internacao,
			        REMOVEFILTERS ( Calendario ),
			        REMOVEFILTERS (
			            Internacao[DATA],
			            Internacao[DT_ENTRADA],
			            Internacao[DATA]
			        )
			    )
			
			RETURN
			COUNTROWS (
			    SUMMARIZE (
			        FILTER (
			            BaseSemFiltroEntrada,
			            Internacao[MOTIVO_ALTA_HOSPITALAR] = "ÓBITO" &&
			            NOT ISBLANK ( Internacao[DT_ALTA] ) &&
			            Internacao[DT_ALTA_DATA] IN DatasSelecionadas &&
			            VAR DataAdm =
			                COALESCE (
			                    Internacao[DT_ENTRADA_URGENCIA],
			                    Internacao[DT_ENTRADA]
			                )
			            RETURN
			                NOT ISBLANK ( DataAdm ) &&
			                DATEDIFF (
			                    DataAdm,
			                    Internacao[DT_ALTA],
			                    HOUR
			                ) >= 24
			        ),
			        Internacao[NR_ATENDIMENTO]
			    )
			)
		formatString: 0
		displayFolder: Altas
		lineageTag: 9b5e864f-247e-4fa7-b673-5f4cf62ebe7f

	measure 'Tx mortalidade hospitalar' = ```
			
