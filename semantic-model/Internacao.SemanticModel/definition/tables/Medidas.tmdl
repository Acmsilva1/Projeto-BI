	measure 'Qtd internacoes (UF x Unid)' = ```
			
			VAR NumUF = [Qtd UF sel (global)]
			RETURN
			SWITCH(
			    TRUE(),
			    
			    -- Caso 1: mais de 1 UF selecionada -> gráfico de REGIONAL (UF)
			    NumUF > 1
			        && ISINSCOPE( Internacao[UF unidade] ),
			        [Qtd internacoes - Regional],
			    
			    -- Caso 2: exatamente 1 UF -> gráfico de UNIDADE
			    NumUF = 1
			        && ISINSCOPE( Internacao[UNIDADE] ),
			        [Qtd internacoes - Unidade],
			    
			    -- Qualquer outro caso: não mostra nada
			    BLANK()
			)
			
			```
		formatString: 0
		displayFolder: Internação
		lineageTag: c0fbeb9b-ddff-433e-9f5e-60da3116ca47

