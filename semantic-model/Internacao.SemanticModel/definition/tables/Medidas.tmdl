	measure 'Leito Disponivel Flag' =
			
			VAR vData = MAX(Calendario[Data])
			VAR vHoje = NOW()
			
			VAR DtCriacao = MAX(Leitos[dt_criacao])
			VAR DtAtualizacao = MAX(Leitos[dt_atualizacao])
			VAR IeSituacao = MAX(Leitos[ie_situacao])
			
			VAR BaseValida =
			    DtCriacao <= vData &&
			    vData <=
			        IF(
			            IeSituacao = "I",
			            COALESCE(DtAtualizacao, vHoje),
			            vHoje
			        )
			
			VAR ForaOperacao =
			    CALCULATE(
			        COUNTROWS(Movimentacao_leitos),
			        REMOVEFILTERS(Movimentacao_leitos[cd_status], Movimentacao_leitos[status]),
			        FILTER(
			            Movimentacao_leitos,
			            Movimentacao_leitos[cd_status] IN {"C","D","E","I","U","M"} && -- C-Manutenção chamado, D-Serviço em pausa, E-Manutenção, I-Interditado, U-Interditado radiação, M-Acompanhante
			            Movimentacao_leitos[dt_historico] <= vData &&
			            vData <= COALESCE(Movimentacao_leitos[dt_fim_historico], vHoje)
			        )
			    ) > 0
			
			RETURN
			    IF(BaseValida && NOT ForaOperacao, 1, 0)
		formatString: 0
		displayFolder: Leitos
		lineageTag: 0d48153f-6513-4508-8f17-0f24d99a5022

	partition Medidas = m
		mode: import
		source =
				let
				    Fonte = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText("i44FAA==", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [#"Coluna 1" = _t]),
				    #"Tipo Alterado" = Table.TransformColumnTypes(Fonte,{{"Coluna 1", type text}}),
				    #"Colunas Removidas" = Table.RemoveColumns(#"Tipo Alterado",{"Coluna 1"})
				in
				    #"Colunas Removidas"

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navegação

