table Custos
	lineageTag: f1ff5e30-b08a-4198-9da5-85aa8dc4162b

	measure qtd_custo_consult = CALCULATE(sum(Custos[QTD_ATENDIDO]),custos[TIPO] = {"CONSULTAS"})
		formatString: 0
		lineageTag: 16f2c108-9294-4667-ab1f-cf42bb41e83c

	measure Qtd_Custo_Dinamico =
			
			SWITCH(
			    TRUE(),
			    SELECTEDVALUE(Custos[TIPO]) = "CONSULTAS",
			        CALCULATE(SUM(Custos[QTD_ATENDIDO]), Custos[TIPO] = "CONSULTAS"),
			    SELECTEDVALUE(Custos[TIPO]) = "LABORATÓRIO",
			        CALCULATE(SUM(Custos[QTD_ATENDIDO]), Custos[TIPO] = "LABORATÓRIO"),
			    SELECTEDVALUE(Custos[TIPO]) = "IMAGEM",
			        CALCULATE(SUM(Custos[QTD_ATENDIDO]), Custos[TIPO] = "IMAGEM"),
			    SELECTEDVALUE(Custos[TIPO]) = "MEDICAMENTOS",
			        CALCULATE(SUM(Custos[QTD_PRODUTO]), Custos[TIPO] = "MEDICAMENTOS", Custos[QTD_PRODUTO] > 0),
			    SELECTEDVALUE(Custos[TIPO]) = "MATERIAL",
			        CALCULATE(SUM(Custos[QTD_PRODUTO]), Custos[TIPO] = "MATERIAL", Custos[QTD_PRODUTO] > 0),
			    BLANK()
			)
		formatString: 0
		lineageTag: ea10c873-0ad7-4076-b2ae-329ca5b44df5

	measure qtd_custo_imagem = CALCULATE(sum(custos[QTd_ATENDIDO]),custos[TIPO] = {"IMAGEM"})
		formatString: 0
		lineageTag: 63896e02-1b27-47b5-be6b-e13e2df4fa6f

	measure qtd_custo_labor = CALCULATE(SUM(Custos[QTD_ATENDIDO]),Custos[TIPO] = "LABORATÓRIO")
		formatString: 0
		lineageTag: 61c0c7d1-538c-4155-8bbd-8b0107c93d4e

	measure qtd_custo_medic = CALCULATE(sum(Custos[QTD_PRODUTO]),custos[TIPO] in {"MEDICAMENTOS","MATERIAL"},(Custos[QTD_PRODUTO]>0))
		formatString: 0
		lineageTag: 2fcea805-5406-42aa-897b-b3c07f37aa1f

	measure sum_custo_consulta = CALCULATE(sum(Custos[TOTAL]),custos[TIPO] in {"CONSULTAS"})
		lineageTag: 9863fd5c-254b-4dbf-8df9-b5c0ab6c5538

	measure sum_custo_imag = CALCULATE(sum(Custos[TOTAL]),custos[TIPO] in {"IMAGEM"})
		lineageTag: 066b4654-ee7b-44ba-9f53-37fa38fcbdc0

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure sum_custo_medic = CALCULATE(sum(Custos[TOTAL]),custos[TIPO] in {"MEDICAMENTOS","MATERIAL"})
		lineageTag: 1dda1241-1582-4789-9285-fb6db2b23a55

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure TicketMedio_geral = DIVIDE(SUM(custos[TOTAL]),DISTINCTCOUNT(custos[ATENDIMENTO]))
		lineageTag: f08e7e00-964f-438b-8d10-ad372864205d

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure TicketMedio_imag =
			
			DIVIDE(
			    CALCULATE(
			        SUM(Custos[TOTAL]),
			        Custos[Tipo] = "IMAGEM"
			    ),
			    CALCULATE(
			        DISTINCTCOUNT(Custos[Atendimento]),
			        Custos[Tipo] = "IMAGEM"
			    )
			)
		lineageTag: 7d66213d-e56a-40da-ab09-955505bd0d02

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure TicketMedio_matmed =
			
			DIVIDE(
			    CALCULATE(
			        SUM(Custos[TOTAL]),
			        Custos[Tipo] in {"MEDICAMENTOS","MATERIAL"},
			        Custos[QTD_PRODUTO] > 0
			    ),
			    CALCULATE(
			        DISTINCTCOUNT(Custos[Atendimento]),
			        Custos[Tipo] IN {"MEDICAMENTOS","MATERIAL"},
			        Custos[QTD_PRODUTO] > 0
			    )
			)
		lineageTag: a5a45d13-f3be-46a2-b042-82d6c7d2bf41

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Total_distinto_contas =
			
			SUMX(
			    VALUES(Custos[ATENDIMENTO]),
			    CALCULATE(SUM(Custos[TOTAL]))
			)
		lineageTag: d231a3e7-07ec-42e3-bee0-c65e5af4d2d3

		annotation PBI_FormatHint = {"isGeneralNumber":true}

