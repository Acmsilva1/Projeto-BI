	column TOTAL = ```
			
			SWITCH(
			    TRUE(),
			    Custos[TIPO] IN {"MEDICAMENTOS","MATERIAL"}, 
			        Custos[QTD_PRODUTO] * Custos[VL_UNITARIO],
			    Custos[TIPO] IN {"IMAGEM","CONSULTAS"}, 
			        Custos[QTD_ATENDIDO] * Custos[VL_UNITARIO],
			    BLANK()
			)
			
			```
		lineageTag: 229b9b7b-74c2-4cd6-aa41-58109e4cf5e3
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column ValorContas = ```
			
			VAR ContaAtual = Custos[ATENDIMENTO]
			VAR Resultado = 
			CALCULATE (
			    SUM ( Custos[TOTAL] ),
			    FILTER ( Custos, Custos[atendimento] = ContaAtual )
			)
			RETURN
			Resultado *1.0
			```
		lineageTag: bddb2d93-0807-4bdd-904a-a37acbcee6ea
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column Ordem_faixas = ```
			
			SWITCH(
			    TRUE(),
			    Custos[ValorContas] <= 200, 1,
			    Custos[ValorContas] <= 400, 2,
			    Custos[ValorContas] <= 600, 3,
			    Custos[ValorContas] <= 1000, 4,
			    Custos[ValorContas] <= 1600, 5,
			    Custos[ValorContas] <= 2200, 6,
			    Custos[ValorContas] <= 3000, 7,
			    Custos[ValorContas] <= 3600, 8,
			    Custos[ValorContas] <= 4200, 9,
			    Custos[ValorContas] <= 7000, 10,
			    Custos[ValorContas] <= 10000, 11,
			    Custos[ValorContas] <= 15000, 12,
			    Custos[ValorContas] <= 20000, 13,
			    14
			)
			
			```
		formatString: 0
		lineageTag: 2b5f95dc-977b-45b5-a6fb-e42968497d01
		summarizeBy: sum

		changedProperty = SortByColumn

		annotation SummarizationSetBy = Automatic

	column Custos_faixas = ```
			
			SWITCH(
			    TRUE(),
			    Custos[ValorContas] <= 200, "0 - 200",
			    Custos[ValorContas] <= 400, "200 - 400",
			    Custos[ValorContas] <= 600, "400 - 600",
			    Custos[ValorContas] <= 1000, "600 - 1.000",
			    Custos[ValorContas] <= 1600, "1.000 - 1.600",
			    Custos[ValorContas] <= 2200, "1.600 - 2.200",
			    Custos[ValorContas] <= 3000, "2.200 - 3.000",
			    Custos[ValorContas] <= 3600, "3.000 - 3.600",
			    Custos[ValorContas] <= 4200, "3.600 - 4.200",
			    Custos[ValorContas] <= 7000, "4.200 - 7.000",
			    Custos[ValorContas] <= 10000, "7.000 - 10.000",
			    Custos[ValorContas] <= 15000, "10.000 - 15.000",
			    Custos[ValorContas] <= 20000, "15.000 - 20.000",
			    "> 20.000"
			)
			
			```
		lineageTag: 82101ef7-72b3-426c-ba11-3aa59dc97d96
		summarizeBy: none
		sortByColumn: Ordem_faixas

		changedProperty = SortByColumn

