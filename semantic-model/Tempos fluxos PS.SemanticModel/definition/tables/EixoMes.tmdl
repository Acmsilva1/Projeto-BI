	column MesAno = FORMAT ( 'EixoMes'[InicioMes], "[$-pt-BR]mmm/yy" )
		lineageTag: 1393b53c-eb17-4c86-8896-7517a646e206
		summarizeBy: none
		sortByColumn: AnoMesSort

		annotation SummarizationSetBy = Automatic

	partition EixoMes = calculated
		mode: import
		source = ```
				
				VAR MinData =
				    CALCULATE ( MIN ( 'Calendario'[Data] ), ALL ( 'Calendario' ) )
				VAR MaxData =
				    CALCULATE ( MAX ( 'Calendario'[Data] ), ALL ( 'Calendario' ) )
				VAR MinMes =
				    DATE ( YEAR ( MinData ), MONTH ( MinData ), 1 )
				VAR MaxMes =
				    DATE ( YEAR ( MaxData ), MONTH ( MaxData ), 1 )
				VAR QtdeMeses =
				    DATEDIFF ( MinMes, MaxMes, MONTH )
				RETURN
				ADDCOLUMNS (
				    GENERATESERIES ( 0, QtdeMeses, 1 ),
				    "InicioMes", EDATE ( MinMes, [Value] ),
				    "Ano", YEAR ( EDATE ( MinMes, [Value] ) ),
				    "MesNum", MONTH ( EDATE ( MinMes, [Value] ) ),
				    "MesNome", FORMAT ( EDATE ( MinMes, [Value] ), "mmmm" ),
				    "AnoMesSort", YEAR ( EDATE ( MinMes, [Value] ) ) * 100 + MONTH ( EDATE ( MinMes, [Value] ) )
				)
				
				```

	annotation PBI_Id = b1a5d66e2d304a3a8e74f39a4570633d

