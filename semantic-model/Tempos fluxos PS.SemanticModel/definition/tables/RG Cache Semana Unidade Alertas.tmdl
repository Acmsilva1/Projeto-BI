	partition 'RG Cache Semana Unidade Alertas' = calculated
		mode: import
		source = ```
				
				VAR _LimiteSigma = 1.5
				VAR Base1 =
				    ADDCOLUMNS (
				        'RG Cache Semana Unidade',
				        "ValorAnterior",
				            VAR _Ind = [Indicador]
				            VAR _Un = [Unidade]
				            VAR _Sem = [SemanaInicio]
				            VAR _SemPrev = _Sem - 7
				            RETURN
				                LOOKUPVALUE (
				                    'RG Cache Semana Unidade'[Valor],
				                    'RG Cache Semana Unidade'[Indicador], _Ind,
				                    'RG Cache Semana Unidade'[Unidade], _Un,
				                    'RG Cache Semana Unidade'[SemanaInicio], _SemPrev
				                )
				    )
				VAR Base =
				    ADDCOLUMNS (
				        Base1,
				        "Delta",
				            VAR _V = [Valor]
				            VAR _Vp = [ValorAnterior]
				            RETURN
				                IF ( ISBLANK ( _V ) || ISBLANK ( _Vp ), BLANK (), _V - _Vp )
				    )
				RETURN
				    ADDCOLUMNS (
				        Base,
				        "ZScore",
				            VAR _Ind = [Indicador]
				            VAR _Un = [Unidade]
				            VAR _Sem = [SemanaInicio]
				            VAR _DataFim = _Sem - 7
				            VAR _DataIni = _DataFim - 7 * 51
				            VAR _BaseHist =
				                FILTER (
				                    Base,
				                    [Indicador] = _Ind
				                        && [Unidade] = _Un
				                        && [SemanaInicio] >= _DataIni
				                        && [SemanaInicio] <= _DataFim
				                        && NOT ISBLANK ( [Delta] )
				                )
				            VAR _Media = AVERAGEX ( _BaseHist, [Delta] )
				            VAR _DP = STDEVX.S ( _BaseHist, [Delta] )
				            VAR _Delta = [Delta]
				            RETURN
				                IF (
				                    ISBLANK ( _Delta ) || ISBLANK ( _DP ) || _DP = 0,
				                    BLANK (),
				                    DIVIDE ( _Delta - _Media, _DP )
				                ),
				        "AlertaVar",
				            VAR _Dir =
				                IF ( [Indicador] = "Desfecho do médico do atend.", 1, -1 )
				            VAR _Delta = [Delta]
				            VAR _Ind = [Indicador]
				            VAR _Un = [Unidade]
				            VAR _Sem = [SemanaInicio]
				            VAR _DataFim = _Sem - 7
				            VAR _DataIni = _DataFim - 7 * 51
				            VAR _BaseHist =
				                FILTER (
				                    Base,
				                    [Indicador] = _Ind
				                        && [Unidade] = _Un
				                        && [SemanaInicio] >= _DataIni
				                        && [SemanaInicio] <= _DataFim
				                        && NOT ISBLANK ( [Delta] )
				                )
				            VAR _Media = AVERAGEX ( _BaseHist, [Delta] )
				            VAR _DP = STDEVX.S ( _BaseHist, [Delta] )
				            VAR _ZScore =
				                IF (
				                    ISBLANK ( _Delta ) || ISBLANK ( _DP ) || _DP = 0,
				                    BLANK (),
				                    DIVIDE ( _Delta - _Media, _DP )
				                )
				            VAR _Favoravel = _Delta * _Dir > 0
				            RETURN
				                IF (
				                    ISBLANK ( _ZScore ),
				                    0,
				                    IF (
				                        ABS ( _ZScore ) < _LimiteSigma,
				                        0,
				                        IF ( _Favoravel, 1, -1 )
				                    )
				                )
				    )
				
				```

	annotation PBI_Id = 9b680a2cbdce4f9489b9f00c617091f4

