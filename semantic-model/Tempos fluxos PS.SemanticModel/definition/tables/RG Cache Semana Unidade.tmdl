table 'RG Cache Semana Unidade'
	lineageTag: ab19157c-5193-4ff5-91f1-312df2f58da1

	column SemanaInicio
		formatString: General Date
		lineageTag: 738b36e8-fbff-4393-b792-f50f4b62baa9
		summarizeBy: none
		isNameInferred
		sourceColumn: [SemanaInicio]

		variation Variation
			isDefault
			relationship: 7576cad6-9047-40d0-8600-935d33f4aef6
			defaultHierarchy: LocalDateTable_5aa2fd57-2c71-4b2e-a87f-d142fe7dd22b.'Hierarquia de datas'

		annotation SummarizationSetBy = Automatic

	column Indicador
		lineageTag: 19d1ed1c-d07c-4ed0-b921-de7797c4b67a
		summarizeBy: none
		isNameInferred
		sourceColumn: [Indicador]

		annotation SummarizationSetBy = Automatic

	column Unidade
		lineageTag: 348e5b76-2cd0-4199-8425-78d7bcb568af
		summarizeBy: none
		isNameInferred
		sourceColumn: [Unidade]

		annotation SummarizationSetBy = Automatic

	column Valor
		lineageTag: 22f7e468-c674-45b2-9d0b-15d99ea49829
		summarizeBy: sum
		isNameInferred
		sourceColumn: [Valor]

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	partition 'RG Cache Semana Unidade' = calculated
		mode: import
		source = ```
				
				VAR DataRef =
				    CALCULATE ( MAX ( fluxo[DT_ENTRADA] ), ALL ( fluxo ) )
				VAR DataInicio =
				    EDATE ( DataRef, -24 ) + 1
				VAR Semanas =
				    SELECTCOLUMNS (
				        SUMMARIZE (
				            FILTER (
				                ALL ( 'Calendario' ),
				                'Calendario'[Data] >= DataInicio
				                    && 'Calendario'[Data] <= DataRef
				            ),
				            'Calendario'[Semana Início]
				        ),
				        "SemanaInicio", 'Calendario'[Semana Início]
				    )
				VAR Indicadores =
				    SELECTCOLUMNS (
				        FILTER (
				            VALUES ( 'Dim Indicadores Volume'[Indicador] ),
				            NOT ISBLANK ( 'Dim Indicadores Volume'[Indicador] )
				        ),
				        "Indicador", 'Dim Indicadores Volume'[Indicador]
				    )
				VAR Unidades =
				    UNION (
				        ROW ( "Unidade", "__TOTAL__" ),
				        SELECTCOLUMNS (
				            FILTER ( VALUES ( fluxo[UNIDADE] ), NOT ISBLANK ( fluxo[UNIDADE] ) ),
				            "Unidade", fluxo[UNIDADE]
				        )
				    )
				RETURN
				    FILTER (
				        ADDCOLUMNS (
				            CROSSJOIN ( Semanas, Indicadores, Unidades ),
				            "Valor",
				                VAR _Sem = [SemanaInicio]
				                VAR _Ind = [Indicador]
				                VAR _Un = [Unidade]
				                RETURN
				                    IF (
				                        _Un = "__TOTAL__",
				                        CALCULATE (
				                            [Valor Indicador Volume RG Base],
				                            TREATAS ( { _Ind }, 'Dim Indicadores Volume'[Indicador] ),
				                            TREATAS ( { _Sem }, 'Calendario'[Semana Início] ),
				                            REMOVEFILTERS ( fluxo[UNIDADE] )
				                        ),
				                        CALCULATE (
				                            [Valor Indicador Volume RG Base],
				                            TREATAS ( { _Ind }, 'Dim Indicadores Volume'[Indicador] ),
				                            TREATAS ( { _Sem }, 'Calendario'[Semana Início] ),
				                            TREATAS ( { _Un }, fluxo[UNIDADE] )
				                        )
				                    )
				        ),
				        NOT ISBLANK ( [Valor] )
				    )
				
				```

	annotation PBI_Id = f6f7e28d74324ef7a6e7e57df0d46d84

