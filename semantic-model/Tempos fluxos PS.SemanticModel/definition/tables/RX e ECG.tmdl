	column 'Diferença Minutos RX_ECG' =
			
			VAR Exame = 'RX e ECG'[DT_EXAME]
			VAR Solic = 'RX e ECG'[DT_SOLICITACAO]
			RETURN
			IF(
			    ISBLANK(Exame) || ISBLANK(Solic),
			    BLANK(),                          // sem uma das datas => nulo
			    ( (Exame - Solic) * 1440 )     // minutos (1440 = 24*60); INT para inteiro
			)
		formatString: 0.00
		lineageTag: 84fd7d60-efec-43b6-9543-4be8e744c1b5
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column HR_RX_ECG = FORMAT('RX e ECG'[DT_SOLICITACAO],"HH:00")
		lineageTag: 06b734fd-d097-487f-bc3c-8cc0e8f77a09
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

