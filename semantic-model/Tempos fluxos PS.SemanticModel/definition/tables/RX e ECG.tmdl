	column DT_CHECAGEM
		dataType: dateTime
		formatString: General Date
		lineageTag: 6bd9b1e5-beb4-4aac-9c46-7ec6d7494282
		summarizeBy: none
		sourceColumn: DT_CHECAGEM

		variation Variation
			isDefault
			relationship: 45baf8f8-41e2-43dc-ada9-70cdfbe445e5
			defaultHierarchy: LocalDateTable_561e3c9a-f371-4c34-b5e6-7b2a96cc1ec3.'Hierarquia de datas'

		annotation SummarizationSetBy = Automatic

	column 'Diferença Minutos RX_ECG Solic/chec' =
			
			VAR Exame = 'RX e ECG'[DT_EXAME]
			VAR Chec  = 'RX e ECG'[DT_CHECAGEM]
			VAR Solic = 'RX e ECG'[DT_SOLICITACAO]
			VAR DataBase =
			    IF(
			        ISBLANK(Chec),
			        Solic,     -- se não tem checagem, usa solicitação
			        Chec       -- senão, usa checagem
			    )
			RETURN
			IF(
			    ISBLANK(Exame) || ISBLANK(DataBase),
			    BLANK(),               -- se faltar uma das duas datas => BLANK
			    (Exame - DataBase) * 1440
			)
		lineageTag: 8b095dab-43ee-4336-998e-5a518f437de4
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

