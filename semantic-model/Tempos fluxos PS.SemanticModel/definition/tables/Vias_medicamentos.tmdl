	column Velocidade
		dataType: string
		lineageTag: 7bd46c2a-45d9-46d7-b35d-ff38910e9650
		summarizeBy: none
		sourceColumn: Velocidade

		annotation SummarizationSetBy = Automatic

	column 'Velocidade Maxima' = ```
			
			CALCULATE(
			    MAX(Vias_medicamentos[Velocidade]),
			    FILTER(
			        Vias_medicamentos,
			        Vias_medicamentos[NR_ATENDIMENTO] = EARLIER(Vias_medicamentos[NR_ATENDIMENTO])
			    )
			)
			
			```
		lineageTag: 00859461-c1ab-40d4-9881-fc9c7459b9c8
		summarizeBy: none

