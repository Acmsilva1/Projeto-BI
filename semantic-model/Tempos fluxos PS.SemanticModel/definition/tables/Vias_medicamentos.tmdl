	column VIA_APLICACAO =
			
			IF(
			    Vias_medicamentos[IE_APLIC_BOLUS] = "S" && Vias_medicamentos[IE_VIA_APLICACAO] = "EV",
			    "EV BOLUS",
			    Vias_medicamentos[IE_VIA_APLICACAO]
			)
		lineageTag: 9af82ae7-acb4-440e-8cc8-97bde54f6661
		summarizeBy: none

